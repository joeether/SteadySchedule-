@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@using System.Security.Claims
@inject

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">SteadySchedule</a>
    </div>
</div>

<input type="checkbox" id="nav-toggle" class="nav-toggle" @bind="navOpen" />

<label for="nav-toggle" class="navbar-toggler"></label>

<div class="nav-scrollable">
    <nav class="flex-column">

    @if (isEmployee)
    {
        <!-- 👷 EMPLOYEE VIEW -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/myschedule" @onclick="CloseMenu">
                My Schedule
            </NavLink>
        </div>
    }
    else
    {
        <!-- 👑 MANAGER VIEW -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/dashboard" @onclick="CloseMenu">
                Dashboard
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="positions" @onclick="CloseMenu">
                Positions
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="shifts" @onclick="CloseMenu">
                Shifts
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="employees" @onclick="CloseMenu">
                Employees
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="assign" @onclick="CloseMenu">
                Assign
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="published" @onclick="CloseMenu">
                Published Schedule
            </NavLink>
        </div>
    }

    <!-- 🔐 AUTH SECTION (same for both) -->
    <div class="nav-item px-3">
        @if (isAuthenticated)
        {
            <form method="post" action="/Account/Logout">
                <AntiforgeryToken />
                <button type="submit"
                        class="nav-link btn btn-link p-0 border-0 text-start w-100"
                        @onclick="CloseMenu">
                    Log Out
                </button>
            </form>

            <div class="nav-link text-muted small">
                @userEmail
            </div>
        }
        else
        {
            <NavLink class="nav-link" href="/Account/Login" @onclick="CloseMenu">
                Log In
            </NavLink>
        }
    </div>

</nav>
</div>

@code {
    private bool isAuthenticated;
    private string? userEmail;
    private bool isEmployee;

    private bool navOpen;

    private void CloseMenu()
    {
        navOpen = false;
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        isAuthenticated = user.Identity?.IsAuthenticated ?? false;
        userEmail = user.Identity?.Name;
        // 🔥 ADD THIS
    isEmployee = user.Claims.Any(c => c.Type == "EmployeeId");
    }
}