@page "/positions"
@using SteadySchedule.Services
@using SteadySchedule.Domain
@inject ScheduleService Schedule

<PageTitle>Positions</PageTitle>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Positions</h2>
        <span class="badge bg-dark">Company: @Schedule.Company.Name</span>
    </div>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="alert alert-warning">@message</div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-header fw-semibold">
            Add Position
        </div>
        <div class="card-body">

            <input class="form-control"
                   placeholder="Enter new position"
                   @bind="newPosition" />

            <button class="btn btn-dark mt-3"
                    @onclick="AddPosition">
                Add Position
            </button>

        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header fw-semibold">
            Existing Positions
        </div>

        <div class="card-body p-0">
            <ul class="list-group list-group-flush">
                @if (!positions.Any())
                {
                    <li class="list-group-item text-muted">No positions yet.</li>
                }
                else
                {
                    @foreach (var p in positions.OrderBy(p => p.Name))
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            @p.Name
                            <button class="btn btn-sm btn-outline-danger"
                                    @onclick="() => DeletePosition(p.Name)">
                                Delete
                            </button>
                        </li>
                    }
                }
            </ul>
        </div>
    </div>

</div>

@code {
    private List<Position> positions = new();
    private string newPosition = string.Empty;
    private string? message;

    protected override async Task OnInitializedAsync()
    {
        await LoadPositionsAsync();
    }

    private async Task LoadPositionsAsync()
    {
        positions = await Schedule.GetPositionsAsync();
    }

    private async Task AddPosition()
    {
        if (string.IsNullOrWhiteSpace(newPosition))
            return;

        var trimmed = newPosition.Trim();

        if (positions.Any(p => string.Equals(p.Name, trimmed, StringComparison.OrdinalIgnoreCase)))
        {
            message = "Position already exists.";
            return;
        }

        await Schedule.AddPositionAsync(trimmed);
        newPosition = string.Empty;
        message = null;

        await LoadPositionsAsync();
    }

    private async Task DeletePosition(string position)
    {
        var deleted = await Schedule.DeletePositionAsync(position);

        if (!deleted)
        {
            message = $"Cannot delete '{position}' because it is used by one or more shifts, or it does not exist.";
            return;
        }

        message = null;
        await LoadPositionsAsync();
    }
}