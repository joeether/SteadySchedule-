@page "/positions"
@using SteadySchedule.Services
@using SteadySchedule.Domain
@using Microsoft.AspNetCore.Components.Authorization
@inject ScheduleService Schedule
@inject IJSRuntime JS
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject UserContextService UserContext

<PageTitle>Positions</PageTitle>

<div class="container mt-4">

    <div class="mb-4">
        <div class="d-flex justify-content-between align-items-end">
            <div>
                <h2 class="fw-bold mb-0">Positions</h2>
                <small class="text-muted">
                    @Schedule.Company.Name
                </small>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="alert alert-warning">@message</div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-header fw-semibold text-muted">
            Add Position
        </div>
        <div class="card-body">

            <div class="d-flex gap-2">
    <input class="form-control"
           placeholder="e.g. Cook, Cashier, Manager"
           @bind="newPosition"
           @onkeypress="HandleKeyPress" />

    <button class="btn btn-primary"
            @onclick="AddPosition"
            disabled="@isAdding">
        @(isAdding ? "Adding..." : "Add")
    </button>
</div>

        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header fw-semibold text-muted">
            Existing Positions
        </div>

        <div class="card-body p-0">
            <ul class="list-group list-group-flush">
                @if (!positions.Any())
                {
                    <li class="list-group-item text-muted">No positions yet. Add your first one above 👆</li>
                }
                else
                {
                    @foreach (var p in positions.OrderBy(p => p.Name))
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center position-item">
    <span class="fw-semibold">@p.Name</span>

    <button class="btn btn-sm btn-outline-danger"
            @onclick="() => DeletePosition(p.Name)"
            disabled="@isDeleting">
        Delete
    </button>
</li>
                    }
                }
            </ul>
        </div>
    </div>

</div>

@code {
    private List<Position> positions = new();
    private string newPosition = string.Empty;
    private string? message;
    private bool isAdding = false;
    private bool isDeleting = false;

    private async Task HandleKeyPress(KeyboardEventArgs e)
{
    if (e.Key == "Enter")
    {
        await AddPosition();
    }
}

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated != true)
            return;

        if (!UserContext.TryInitializeCompany(user, Schedule))
            return;

        await LoadPositionsAsync();
    }

    private async Task LoadPositionsAsync()
    {
        positions = await Schedule.GetPositionsAsync(Schedule.Company.Id);
    }

    private async Task AddPosition()
    {
        if (isAdding)
            return;

        isAdding = true;

        try
        {
            if (string.IsNullOrWhiteSpace(newPosition))
                return;

            var trimmed = newPosition.Trim();

            if (positions.Any(p => string.Equals(p.Name, trimmed, StringComparison.OrdinalIgnoreCase)))
            {
                message = "Position already exists.";
                return;
            }

            await Schedule.AddPositionAsync(trimmed, Schedule.Company.Id);
            newPosition = string.Empty;
            message = null;

            await LoadPositionsAsync();
        }
        finally
        {
            isAdding = false;
        }
    }

    private async Task DeletePosition(string position)
    {
        if (isDeleting)
            return;

        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Delete '{position}'?");

        if (!confirmed)
            return;

        isDeleting = true;

        try
        {
            var deleted = await Schedule.DeletePositionAsync(position, Schedule.Company.Id);

            if (!deleted)
            {
                message = $"Cannot delete '{position}' because it is used by one or more shifts, or it does not exist.";
                return;
            }

            message = null;
            await LoadPositionsAsync();
        }
        finally
        {
            isDeleting = false;
        }
    }
}