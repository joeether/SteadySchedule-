@page "/"
@using SteadySchedule.Domain
@using SteadySchedule.Services
@inject ScheduleService Schedule

<PageTitle>Dashboard</PageTitle>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">Dashboard</h2>
        <span class="badge bg-dark">Company: @Schedule.Company.Name</span>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-md-4 col-lg-2">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">Employees</div>
                    <div class="fs-4 fw-bold">@TotalEmployees</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-4 col-lg-2">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">Shifts This Week</div>
                    <div class="fs-4 fw-bold">@shiftsThisWeek.Count</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-4 col-lg-2">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">Assigned</div>
                    <div class="fs-4 fw-bold">@AssignedShiftCount</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-4 col-lg-2">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">Open Shifts</div>
                    <div class="fs-4 fw-bold">@OpenShiftCount</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-4 col-lg-2">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">Warnings</div>
                    <div class="fs-4 fw-bold">@WarningCount</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-4 col-lg-2">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">Week Status</div>
                    <div class="fw-bold">@CurrentWeekStatus</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header fw-semibold">
            This Week Overview
        </div>
        <div class="card-body">
            <div><strong>Week of:</strong> @weekStart.ToString("MMM d, yyyy")</div>
            <div><strong>Company:</strong> @Schedule.Company.Name</div>
            <div><strong>Published Weeks:</strong> @PublishedWeekCount</div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header fw-semibold">
            Warning Shifts
        </div>
        <div class="card-body">
            @if (!WarningShifts.Any())
            {
                <div class="text-muted">No warning shifts this week.</div>
            }
            else
            {
                <ul class="list-group list-group-flush">
                    @foreach (var shift in WarningShifts)
                    {
                        <li class="list-group-item">
                            <div class="fw-semibold">@shift.Position</div>

                            <small class="d-block mb-1">
                                @shift.Date.ToString("ddd M/d")
                                |
                                @shift.StartTime.ToString(@"hh\:mm") - @shift.EndTime.ToString(@"hh\:mm")
                                |
                                @GetShiftWarningCount(shift) warning(s)
                            </small>

                            @foreach (var detail in GetShiftWarningDetails(shift))
                            {
                                <div>
                                    <span class="badge bg-warning text-dark me-1">@detail</span>
                                </div>
                            }
                        </li>
                    }
                </ul>
            }
        </div>
    </div>

</div>

@code {
    private DateTime weekStart = ScheduleService.StartOfWeek(DateTime.Today);
    private DateTime WeekEnd => weekStart.AddDays(7);

    private int TotalEmployees => employees.Count;

    private List<Employee> employees = new();
    private List<Shift> shiftsThisWeek = new();
    private List<Assignment> assignmentsThisWeek = new();
    private WeekStatus currentWeekStatus = WeekStatus.Draft;
    private int publishedWeekCount = 0;

    protected override async Task OnInitializedAsync()
{
    await LoadDashboardData();
}

private async Task LoadDashboardData()
{
    employees = await Schedule.GetEmployeesAsync();
    shiftsThisWeek = await Schedule.GetWeekShiftsAsync(Schedule.Company.Id, weekStart);
    assignmentsThisWeek = await Schedule.GetWeekAssignmentsAsync(Schedule.Company.Id, weekStart);
    currentWeekStatus = await Schedule.GetWeekStatusAsync(weekStart);
    publishedWeekCount = (await Schedule.GetPublishedSchedulesAsync()).Count;
}

protected override async Task OnParametersSetAsync()
{
    await LoadDashboardData();
}

    private int AssignedShiftCount =>
        shiftsThisWeek.Count(s => assignmentsThisWeek.Any(a => a.ShiftId == s.Id));

    private int OpenShiftCount =>
        shiftsThisWeek.Count - AssignedShiftCount;

    private WeekStatus CurrentWeekStatus =>
        currentWeekStatus;

    private int PublishedWeekCount =>
        publishedWeekCount;

    private int WarningCount =>
        shiftsThisWeek.Sum(GetShiftWarningCount);

    private List<Shift> WarningShifts =>
        shiftsThisWeek.Where(s => GetShiftWarningCount(s) > 0).ToList();

    private int GetShiftWarningCount(Shift shift)
    {
        var assignedEmployees = assignmentsThisWeek
            .Where(a => a.ShiftId == shift.Id)
            .Select(a => employees.FirstOrDefault(e => e.Id == a.EmployeeId))
            .Where(e => e != null)
            .Cast<Employee>()
            .ToList();

        return assignedEmployees.Sum(e => GetWarnings(e, shift).Count);
    }

    private List<string> GetWarnings(Employee e, Shift shift)
    {
        var warnings = new List<string>();

        if (!IsAvailableForShift(e, shift))
            warnings.Add("Availability conflict");

        if (IsOvertimeWarningForAssignedShift(e, shift))
            warnings.Add("Overtime risk");

        return warnings;
    }

    private bool IsOvertimeWarningForAssignedShift(Employee e, Shift targetShift)
    {
        var employeeWeekShifts = assignmentsThisWeek
            .Where(a => a.EmployeeId == e.Id)
            .Join(Schedule.Shifts,
                  a => a.ShiftId,
                  s => s.Id,
                  (a, s) => s)
            .Where(s => s.Date >= weekStart && s.Date < WeekEnd)
            .OrderBy(s => s.Date)
            .ThenBy(s => s.StartTime)
            .ToList();

        double runningHours = 0;
        bool alreadyCrossed = false;

        foreach (var s in employeeWeekShifts)
        {
            var shiftHours = (s.EndTime - s.StartTime).TotalHours;

            if (!alreadyCrossed && runningHours + shiftHours > e.MaxHoursPerWeek)
            {
                alreadyCrossed = true;
            }

            if (s.Id == targetShift.Id)
            {
                return alreadyCrossed;
            }

            runningHours += shiftHours;
        }

        return false;
    }

    private int GetWeeklyHours(Employee employee)
    {
        var employeeAssignments = assignmentsThisWeek
            .Where(a => a.EmployeeId == employee.Id)
            .Join(Schedule.Shifts,
                  a => a.ShiftId,
                  s => s.Id,
                  (a, s) => s)
            .Where(s => s.Date >= weekStart && s.Date < WeekEnd);

        return employeeAssignments.Sum(s => (int)(s.EndTime - s.StartTime).TotalHours);
    }

    private static bool IsAvailableForShift(Employee e, Shift shift)
    {
        bool dayAvailable;
        TimeSpan? start;
        TimeSpan? end;

        switch (shift.Date.DayOfWeek)
        {
            case DayOfWeek.Monday:
                dayAvailable = e.MondayAvailable;
                start = e.MondayStart;
                end = e.MondayEnd;
                break;
            case DayOfWeek.Tuesday:
                dayAvailable = e.TuesdayAvailable;
                start = e.TuesdayStart;
                end = e.TuesdayEnd;
                break;
            case DayOfWeek.Wednesday:
                dayAvailable = e.WednesdayAvailable;
                start = e.WednesdayStart;
                end = e.WednesdayEnd;
                break;
            case DayOfWeek.Thursday:
                dayAvailable = e.ThursdayAvailable;
                start = e.ThursdayStart;
                end = e.ThursdayEnd;
                break;
            case DayOfWeek.Friday:
                dayAvailable = e.FridayAvailable;
                start = e.FridayStart;
                end = e.FridayEnd;
                break;
            case DayOfWeek.Saturday:
                dayAvailable = e.SaturdayAvailable;
                start = e.SaturdayStart;
                end = e.SaturdayEnd;
                break;
            case DayOfWeek.Sunday:
                dayAvailable = e.SundayAvailable;
                start = e.SundayStart;
                end = e.SundayEnd;
                break;
            default:
                return true;
        }

        if (!dayAvailable)
            return false;

        if (!start.HasValue || !end.HasValue)
            return false;

        return shift.StartTime >= start.Value && shift.EndTime <= end.Value;
    }

    private List<string> GetShiftWarningDetails(Shift shift)
    {
        var warningDetails = new List<string>();

        var assignedEmployees = assignmentsThisWeek
            .Where(a => a.ShiftId == shift.Id)
            .Select(a => employees.FirstOrDefault(e => e.Id == a.EmployeeId))
            .Where(e => e != null)
            .Cast<Employee>()
            .ToList();

        foreach (var employee in assignedEmployees)
        {
            var warnings = GetWarnings(employee, shift);

            foreach (var warning in warnings)
            {
                warningDetails.Add($"{employee.Name}: {warning}");
            }
        }

        return warningDetails;
    }
}