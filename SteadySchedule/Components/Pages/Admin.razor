@page "/admin"

@using SteadySchedule.Domain
@using SteadySchedule.ViewModels
@using SteadySchedule.Data
@using Microsoft.EntityFrameworkCore
@inject AppDbContext _context
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider

<h3>Admin Dashboard</h3>

@if (companies == null)
{
    <p>Loading...</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Trial Ends</th>
                <th>Next Pay</th>
                <th>Active</th>
                <th>Employees</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var company in companies)
            {
                <tr>
                    <td>@company.Name</td>
                    <td>@company.AdminEmail</td>
                    <td>

<td>
    @(company.TrialEndDate.ToLocalTime().ToString("MMM d"))
</td>

<td>
    @(company.NextBillingDate.ToLocalTime().ToString("MMM d"))
</td>
                        @(company.IsActive ? "✅" : "❌")
                    </td>
<td>@company.EmployeeCount</td>
                    <td>
                        <button class="btn btn-sm btn-primary"
                                @onclick="() => ToggleActive(company.Id)">
                            Toggle
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<CompanyViewModel>? companies;

    public DateTime TrialEndDate { get; set; }
public int BillingAnchorDay { get; set; }
public DateTime NextBillingDate { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await AuthorizeAdmin();
        await LoadCompanies();
    }

    private async Task AuthorizeAdmin()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        // CHANGE THIS TO YOUR EMAIL
        if (user.Identity?.Name != "collinjonahsdad@gmail.com")
        {
            NavigationManager.NavigateTo("/");
        }
    }

    private async Task LoadCompanies()
    {
        var today = DateTime.UtcNow;

companies = await _context.Companies
    .Select(c => new CompanyViewModel
    {
        Id = c.Id,
        Name = c.Name,
        AdminEmail = c.AdminEmail,
        IsActive = c.IsActive,
        EmployeeCount = _context.Employees.Count(e => e.CompanyId == c.Id),
        TrialEndDate = c.TrialEndDate,
        BillingAnchorDay = c.BillingAnchorDay,

        NextBillingDate = new DateTime(
            today.AddMonths(1).Year,
            today.AddMonths(1).Month,
            Math.Min(c.BillingAnchorDay,
                DateTime.DaysInMonth(
                    today.AddMonths(1).Year,
                    today.AddMonths(1).Month))
        )
    })
    .ToListAsync();
    }

    private async Task ToggleActive(int companyId)
{
    var company = await _context.Companies.FindAsync(companyId);

    if (company != null)
    {
        company.IsActive = !company.IsActive;
        await _context.SaveChangesAsync();
    }

    await LoadCompanies();
}
}