	private async Task AddShiftToWeek()
	{
		await RunBusy(async () =>
		{
			if (IsPublished) return;
			if (string.IsNullOrWhiteSpace(newShiftPosition)) return;

			if (newShiftCount < 1)
				newShiftCount = 1;

			var shiftDate = weekStart.AddDays(newShiftDayOffset);
			var slotGroupId = Guid.NewGuid().ToString();
			addShiftMessage = null;

			if (IsInvalidSundayShift(shiftDate, newShiftStart, newShiftEnd))
			{
				addShiftMessage = "Sunday shifts cannot extend past 12:00 AM. To cover an overnight shift, split it into a Sunday shift and a Monday shift.";
				return;
			}

			for (int i = 0; i < newShiftCount; i++)
			{
				await Schedule.AddShiftAsync(new Shift
				{
					CompanyId = Schedule.Company.Id,
					Date = shiftDate,
					Position = newShiftPosition,
					StartTime = newShiftStart,
					EndTime = newShiftEnd,
					SlotGroupId = slotGroupId
				});
			}

			await LoadWeekDataAsync();

			newShiftCount = 1;
			showAddShiftModal = false;
		});
	}

