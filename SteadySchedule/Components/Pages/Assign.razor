	private bool WouldCauseOvertimeIfAssigned(Employee e, Shift shift)
	{
		var currentHours = GetWeeklyHours(e);
		var shiftHours = GetShiftHours(shift);
		return currentHours + shiftHours > e.MaxHoursPerWeek;
	}

	private bool IsOvertimeWarningForAssignedShift(Employee e, Shift targetShift)
	{
		var employeeWeekShifts = assignments
			.Where(a => a.EmployeeId == e.Id)
			.Join(shifts,
				a => a.ShiftId,
				s => s.Id,
				(a, s) => s)
			.Where(s => s.Date >= weekStart && s.Date < WeekEnd)
			.OrderBy(s => s.Date)
			.ThenBy(s => s.StartTime)
			.ToList();

		double runningHours = 0;
		bool alreadyCrossed = false;

		foreach (var s in employeeWeekShifts)
		{
			var shiftHours = GetShiftHours(s);
			if (!alreadyCrossed && runningHours + shiftHours > e.MaxHoursPerWeek)
			{
				alreadyCrossed = true;
			}

			if (s.Id == targetShift.Id)
			{
				return alreadyCrossed;
			}

			runningHours += shiftHours;
		}

		return false;
	}

	private class ShiftGroup
	{
		public string Position { get; set; } = "";
		public DateTime Date { get; set; }
		public TimeSpan StartTime { get; set; }
		public TimeSpan EndTime { get; set; }
		public List<Shift> Shifts { get; set; } = new();

		public int Total => Shifts.Count;
	}

	private List<ShiftGroup> GetShiftGroupsForDay(DateTime day)
	{
		return shifts
			.Where(s => s.Date.Date == day.Date)
			.GroupBy(s => new
			{
				s.Position,
				s.StartTime,
				s.EndTime
			})
			.Select(g => new ShiftGroup
			{
				Position = g.Key.Position,
				Date = day,
				StartTime = g.Key.StartTime,
				EndTime = g.Key.EndTime,
				Shifts = g.OrderBy(s => s.Id).ToList()
			})
			.OrderBy(g => g.StartTime)
			.ThenBy(g => g.Position)
			.ToList();
	}

	private int GetFilledCount(ShiftGroup group)
	{
		return group.Shifts.Count(s => assignments.Any(a => a.ShiftId == s.Id));
	}

	private Shift GetPreferredShiftFromGroup(ShiftGroup group)
	{
		var openShift = group.Shifts
			.FirstOrDefault(s => !assignments.Any(a => a.ShiftId == s.Id));

		return openShift ?? group.Shifts.First();
	}

	private Dictionary<DateTime, Dictionary<string, List<string>>> GetWeeklyWarnings()
	{
		var result = new Dictionary<DateTime, Dictionary<string, List<string>>>();

		var weekShifts = shifts
			.Where(s => s.Date >= weekStart && s.Date < WeekEnd);

		foreach (var shift in weekShifts)
		{
			foreach (var a in assignments.Where(a => a.ShiftId == shift.Id))
			{
				var emp = employees.First(x => x.Id == a.EmployeeId);
				var warnings = GetWarnings(emp, shift, isPreview: false);

				if (!warnings.Any()) continue;

				if (!result.ContainsKey(shift.Date))
					result[shift.Date] = new Dictionary<string, List<string>>();

				if (!result[shift.Date].ContainsKey(emp.Name))
					result[shift.Date][emp.Name] = new List<string>();

				result[shift.Date][emp.Name].AddRange(warnings);
			}
		}

		return result;
	}

	private int GetWeeklyWarningCount()
	{
		return GetWeeklyWarnings()
			.Sum(day => day.Value.Sum(emp => emp.Value.Count));
	}

	private double GetWeeklyHours(int employeeId, DateTime weekStart)
	{
		var weekEnd = weekStart.AddDays(7);

		return assignments
			.Where(a => a.EmployeeId == employeeId)
			.Join(shifts,
				a => a.ShiftId,
				s => s.Id,
				(a, s) => s)
			.Where(s => s.Date >= weekStart && s.Date < weekEnd)
			.Sum(s => GetShiftHours(s));
	}

	private IEnumerable<Assignment> GetAssignmentsForSelectedGroup()
	{
		if (selectedGroup is null)
			return Enumerable.Empty<Assignment>();

		var shiftIds = selectedGroup.Shifts.Select(s => s.Id).ToHashSet();

		return assignments.Where(a => shiftIds.Contains(a.ShiftId));
	}

