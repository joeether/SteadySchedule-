	private async Task LoadTemplateIntoWeek()
	{
		await RunBusy(async () =>
		{
			if (IsPublished) return;

			var selectedTemplateShifts = templateShifts
				.Where(s => s.WeekTemplateId == selectedTemplateId)
				.ToList();

			int addedCount = 0;

			foreach (var ts in selectedTemplateShifts)
			{
				var shiftDate = weekStart.AddDays(((int)ts.DayOfWeek - (int)DayOfWeek.Monday + 7) % 7);

				int existingCount = shifts.Count(s =>
					s.Date == shiftDate &&
					s.Position == ts.Position &&
					s.StartTime == ts.StartTime &&
					s.EndTime == ts.EndTime);

				int neededCount = ts.Count - existingCount;

				var slotGroupId = Guid.NewGuid().ToString();

				for (int i = 0; i < neededCount; i++)
				{
					await Schedule.AddShiftAsync(new Shift
					{
						CompanyId = Schedule.Company.Id,
						Date = shiftDate,
						Position = ts.Position,
						StartTime = ts.StartTime,
						EndTime = ts.EndTime,
						SlotGroupId = slotGroupId
					});

					addedCount++;
				}
			}

			shifts = await Schedule.GetWeekShiftsAsync(Schedule.Company.Id, weekStart);
			assignmentsThisWeek = await Schedule.GetWeekAssignmentsAsync(Schedule.Company.Id, weekStart);

			if (addedCount > 0)
			{
				templateWasSuccess = true;
				templateMessage = $"{addedCount} shifts loaded from template.";
			}
			else
			{
				templateWasSuccess = false;
				templateMessage = "No new shifts added (they may already exist).";
			}

			showTemplateModal = false;

			StateHasChanged();
			await Task.Delay(3000);
			templateMessage = null;
			StateHasChanged();
		});
	}

	private async Task ClearWeek()
	{
		var confirmed = await JS.InvokeAsync<bool>(
			"confirm",
			"Clear ALL shifts for this week? This cannot be undone."
		);

		if (!confirmed)
			return;

		await RunBusy(async () =>
		{
			if (IsPublished)
				return;

			if (!shifts.Any())
			{
				clearWeekWasSuccess = false;
				clearWeekMessage = "There were no shifts to clear for this week.";
				StateHasChanged();
				await Task.Delay(3000);
				clearWeekMessage = null;
				StateHasChanged();
				return;
			}

			await Schedule.ClearWeekAsync(weekStart);

			shifts = await Schedule.GetWeekShiftsAsync(Schedule.Company.Id, weekStart);
			assignmentsThisWeek = await Schedule.GetWeekAssignmentsAsync(Schedule.Company.Id, weekStart);

			selectedShift = null;
			showAssignModal = false;
			openWarningShiftId = null;

			clearWeekWasSuccess = true;
			clearWeekMessage = "Week cleared successfully.";

			StateHasChanged();
			await Task.Delay(3000);
			clearWeekMessage = null;
			StateHasChanged();
		});
	}

