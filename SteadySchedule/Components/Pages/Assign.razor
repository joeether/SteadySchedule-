@page "/assign"
@using SteadySchedule.Domain
@using SteadySchedule.Services
@inject ScheduleService Schedule
@inject NavigationManager Nav

<PageTitle>Assign</PageTitle>



<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center gap-2">
            <h2 class="fw-bold mb-0">Two-Click Assign</h2>

            <span class="badge @StatusBadgeClass ms-2">
                @StatusLabel
            </span>
        </div>

        <div class="d-flex align-items-center gap-2">
            @if (!IsPublished)
            {
                <button class="btn btn-dark btn-sm" @onclick="PublishThisWeek">
                    Publish Week
                </button>
            }
            else
            {
                <button class="btn btn-outline-dark btn-sm" @onclick="UnpublishThisWeek">
                    Unpublish (In Review)
                </button>
            }

            @if (openedFromPublished)
            {
                <div class="alert alert-info">
                    Editing Week of @weekStart.ToString("MMMM d") — Previously Published
                </div>
            }

            <span class="badge bg-dark">Company: Mama's Burger Joint</span>
        </div>
    </div>

    @if (IsInReview)
    {
        <div class="alert alert-warning">
            This schedule is <strong>In Review</strong> and may change.
        </div>
    }

    <div class="form-check form-switch mt-2">
        <input class="form-check-input" type="checkbox" @bind="allowOvertime">
        <label class="form-check-label">
            Allow Overtime
        </label>
    </div>

    <div class="row g-4">

        <!-- Shifts Panel -->
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="fw-semibold">
                    Week of @weekStart.ToString("MMM d, yyyy")
                </div>

                <div class="btn-group">
                    <button class="btn btn-outline-dark btn-sm" @onclick="PrevWeek">◀ Prev</button>
                    <button class="btn btn-outline-dark btn-sm" @onclick="() => weekStart = StartOfWeek(DateTime.Today, DayOfWeek.Monday)">Today</button>
                    <button class="btn btn-outline-dark btn-sm" @onclick="NextWeek">Next ▶</button>
                </div>
            </div>

            <div class="row g-3">
                @for (int i = 0; i < 7; i++)
                {
                    var day = Day(i);
                    var dayShifts = shifts
                    .Where(s => s.Date.Date == day.Date)
                    .OrderBy(s => s.StartTime)
                    .ToList();

                    <div class="col-12 col-md">
                        <div class="card shadow-sm h-100">
                            <div class="card-header fw-semibold">
                                <div>@day.ToString("ddd")</div>
                                <small class="text-muted">@day.ToString("M/d")</small>
                            </div>

                            <div class="card-body p-2">
                                @if (!dayShifts.Any())
                                {
                                    <div class="text-muted small">No shifts</div>
                                }
                                else
                                {
                                    @foreach (var s in dayShifts)
                                    {
                                        <div class="border rounded p-2 mb-2 @(selectedShift?.Id == s.Id ? "bg-dark text-white" : "")"
                                             style="cursor:pointer"
                                             @onclick="() => { if (!IsPublished) SelectShift(s); else selectedShift = s; }">
                                            <div class="fw-semibold">@s.Position</div>
                                            <div class="small">
                                                @s.StartTime.ToString(@"hh\:mm") - @s.EndTime.ToString(@"hh\:mm")
                                            </div>

                                            @* quick assignment chips *@
                                            <div class="mt-1">
                                                @foreach (var a in assignments.Where(a => a.ShiftId == s.Id))
                                                {
                                                    var emp = employees.First(x => x.Id == a.EmployeeId);
                                                    <span class="badge bg-success me-1">@emp.Name</span>
                                                }
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Employees Panel -->
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header fw-semibold">
                    Eligible Employees
                </div>
                <div class="card-body">

                    @if (IsPublished)
                    {
                        <div class="alert alert-info">
                            This week is <strong>Official</strong>. Unpublish the week to make changes.
                        </div>
                    }

                    @if (selectedShift is null)
                    {
                        <p class="text-muted">Select a shift to see eligible employees.</p>
                    }
                    else
                    {
                        <ul class="list-group">
                            @foreach (var e in EligibleEmployees(selectedShift))
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-semibold">@e.Name</div>
                                        <small class="text-muted">
                                            Max @e.MaxHoursPerWeek hrs/week
                                        </small>
                                    </div>
                                    <button class="btn btn-sm btn-dark"
                                            disabled="@IsPublished"
                                            title="@(IsPublished ? "Week is Official. Unpublish to edit." : "")"
                                            @onclick="() => AssignEmployee(selectedShift, e)">
                                        Assign
                                    </button>
                                </li>
                            }
                        </ul>

                        <hr />

                        <h6 class="fw-bold">Assignments</h6>

                        @foreach (var a in assignments.Where(a => a.ShiftId == selectedShift.Id))
                        {
                            var emp = employees.First(x => x.Id == a.EmployeeId);

                            <span class="badge bg-success me-1"
                                  style="cursor:@(IsPublished ? "not-allowed" : "pointer"); opacity:@(IsPublished ? "0.6" : "1");"
                                  title="@(IsPublished ? "Week is Official. Unpublish to edit." : "Click to unassign")"
                                  @onclick="() => TryUnassign(a)">
                                @emp.Name ✕
                            </span>
                        }
                    }
                </div>
            </div>
        </div>

    </div>
</div>

@code {

    private DateTime weekStart;

    private WeekStatus CurrentWeekStatus => Schedule.GetWeekStatus(weekStart);

    private bool IsPublished => CurrentWeekStatus == WeekStatus.Published;

    private bool IsInReview => CurrentWeekStatus == WeekStatus.InReview;

    private List<Employee> employees => Schedule.Employees;

    private List<Shift> shifts => Schedule.Shifts;

    private List<Assignment> assignments => Schedule.Assignments;

    private Shift? selectedShift;

    private bool allowOvertime = false;

    private void PrevWeek() => weekStart = weekStart.AddDays(-7);

    private void NextWeek() => weekStart = weekStart.AddDays(7);

    private DateTime WeekEnd => weekStart.AddDays(7);

    private DateTime Day(int offset) => weekStart.AddDays(offset);

    private Company company => Schedule.Company;

    bool openedFromPublished = false;

    protected override void OnInitialized()
    {
        LoadWeekFromQuery();
        weekStart = StartOfWeek(DateTime.Today, DayOfWeek.Monday);

        var uri = new Uri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var weekStr = query["week"];

        if (!string.IsNullOrWhiteSpace(weekStr) && DateTime.TryParse(weekStr, out var requested))
        {
            weekStart = StartOfWeek(requested, DayOfWeek.Monday);
        }
        selectedShift = null;
    }

    private static DateTime StartOfWeek(DateTime date, DayOfWeek startDay)
    {
        int diff = (7 + (date.DayOfWeek - startDay)) % 7;
        return date.Date.AddDays(-diff);
    }

    private void Unassign(Assignment assignment)
    {
        if (IsPublished) return;
        Schedule.Assignments.Remove(assignment);
    }

    private int GetWeeklyHours(Employee employee)
    {
        var employeeAssignments = assignments
            .Where(a => a.EmployeeId == employee.Id)
            .Join(shifts,
                  a => a.ShiftId,
                  s => s.Id,
                  (a, s) => s)
            .Where(s => s.Date >= weekStart && s.Date < WeekEnd);

        return employeeAssignments.Sum(s => (int)(s.EndTime - s.StartTime).TotalHours);
    }

    private static bool IsQualified(Employee e, string position)
    {
        return (e.PositionsQualified ?? "")
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Any(p => string.Equals(p, position, StringComparison.OrdinalIgnoreCase));
    }

    private void SelectShift(Shift s)
    {
        selectedShift = s;
    }

    private IEnumerable<Employee> EligibleEmployees(Shift shift)
    {
        return employees
            .Where(e => e.CompanyId == shift.CompanyId)
            .Where(e => IsQualified(e, shift.Position))
            .Where(e => !assignments.Any(a => a.ShiftId == shift.Id && a.EmployeeId == e.Id))
            .Where(e =>
            {
                // HARD RULE: no overlapping shifts
                var overlapping = assignments
                    .Where(a => a.EmployeeId == e.Id)
                    .Join(shifts,
                          a => a.ShiftId,
                          s => s.Id,
                          (a, s) => s)
                    .Any(existingShift =>
                        existingShift.Date == shift.Date &&
                        existingShift.StartTime < shift.EndTime &&
                        shift.StartTime < existingShift.EndTime
                    );

                if (overlapping)
                    return false;

                // SOFT RULE: weekly hours (can be bypassed)
                if (!allowOvertime)
                {
                    var currentHours = GetWeeklyHours(e);
                    var shiftHours = (int)(shift.EndTime - shift.StartTime).TotalHours;

                    if (currentHours + shiftHours > e.MaxHoursPerWeek)
                        return false;
                }

                return true;
            });
    }

    private void AssignEmployee(Shift shift, Employee employee)
    {
        if (IsPublished) return;

        assignments.Add(new Assignment
        {
            Id = assignments.Count + 1,
            ShiftId = shift.Id,
            EmployeeId = employee.Id,
            ApprovedOvertime = false
        });
    }

    private string StatusLabel => CurrentWeekStatus switch
    {
        WeekStatus.Published => "Official",
        WeekStatus.InReview => "In Review",
        _ => "Draft"
    };

    private string StatusBadgeClass => CurrentWeekStatus switch
    {
        WeekStatus.Published => "bg-success",
        WeekStatus.InReview => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    private void TryUnassign(Assignment a)
    {
        if (IsPublished) return;
        Unassign(a);
    }

    void LoadWeekFromQuery()
    {
        var uri = new Uri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);

        var weekStr = query["week"];

        if (!string.IsNullOrEmpty(weekStr))
        {
            if (DateTime.TryParse(weekStr, out var week))
            {
                weekStart = week;
                openedFromPublished = true;
            }
        }
    }

    private void PublishThisWeek() => Schedule.PublishWeek(weekStart);

    // Per our workflow: unpublish means "In Review"
    private void UnpublishThisWeek() => Schedule.UnpublishWeek(weekStart);
}