	private static double GetShiftHours(Shift shift)
	{
		var start = shift.StartTime;
		var end = shift.EndTime;

		if (end < start)
		{
			return (TimeSpan.FromHours(24) - start + end).TotalHours;
		}

		if (end == start)
		{
			return 24;
		}

		return (end - start).TotalHours;
	}
