	private List<string> GetWarningsForShift(Shift s)
	{
		var warnings = new List<string>();

		foreach (var a in assignments.Where(x => x.ShiftId == s.Id))
		{
			var emp = employees.First(x => x.Id == a.EmployeeId);
			var empWarnings = GetWarnings(emp, s, isPreview: false);

			foreach (var w in empWarnings)
			{
				warnings.Add($"{emp.Name}: {w}");
			}
		}

		return warnings;
	}

