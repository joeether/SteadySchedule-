@page "/employees"
@using SteadySchedule.Domain
@using SteadySchedule.Services
@inject ScheduleService Schedule
@inject IJSRuntime JS
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization

<PageTitle>Employees</PageTitle>

<div class="container mt-4">

	<div class="mb-4">
		<div class="d-flex justify-content-between align-items-end">
			<div>
				<h2 class="fw-bold mb-0">Employees</h2>
				<small class="text-muted">
					@Schedule.Company.Name
				</small>
			</div>
		</div>
	</div>

	<div id="employee-form" class="card shadow-sm mb-4">
		<div class="card-header fw-semibold">
			Add Employee
		</div>
		<div class="card-body">

			<div class="row g-3">

				<div class="col-md-4">
					<label class="form-label">Name</label>
					<input class="form-control" @bind="newEmployee.Name" />
				</div>

				<div class="col-md-4">
					<label class="form-label">Email</label>
					<input class="form-control" @bind="newEmployee.Email" />
				</div>

				<div class="col-md-4">
					<label class="form-label">Max Hours / Week</label>
					<input type="number" class="form-control" @bind="newEmployee.MaxHoursPerWeek" />
				</div>

				<div class="col-md-4">
					<label class="form-label d-block">Pay Type</label>
					<div class="btn-group" role="group">
						<button type="button"
								class="btn @(newEmployee.IsSalary ? "btn-outline-secondary" : "btn-primary")"
								@onclick='() => SetPayType(false)'>
							Hourly
						</button>
						<button type="button"
								class="btn @(newEmployee.IsSalary ? "btn-primary" : "btn-outline-secondary")"
								@onclick='() => SetPayType(true)'>
							Salary / Week
						</button>
					</div>
				</div>

				@if (!newEmployee.IsSalary)
				{
					<div class="col-md-4">
						<label class="form-label">Hourly Rate</label>
						<InputNumber @bind-Value="newEmployee.HourlyRate" class="form-control" />
					</div>
				}
				else
				{
					<div class="col-md-4">
						<label class="form-label">Weekly Salary</label>
						<InputNumber @bind-Value="newEmployee.WeeklySalary" class="form-control" />
					</div>
				}

				<div class="col-12">
					<label class="form-label">Jobs They Can Work</label>

					@foreach (var position in ExistingPositions)
					{
						<div class="form-check">
							<input class="form-check-input"
								   type="checkbox"
								   checked="@IsPositionSelected(position)"
								   @onchange="(e) => TogglePosition(position, (bool)e.Value!)" />

							<label class="form-check-label">
								@position
							</label>
						</div>
					}
						</div>
					<div class="col-12">
						<label class="form-label fw-semibold">Availability</label>


<div class="form-check mb-2">
    <input type="checkbox"
           class="form-check-input"
           checked="@newEmployee.IsAnytime"
@onchange="e => ToggleAnytime((bool)e.Value!)" />
    <label class="form-check-label fw-semibold">
        Available Anytime (for selected days)
    </label>
</div>
						<div class="table-responsive">
							<table class="table table-sm align-middle">
								<thead>
									<tr>
										<th>Day</th>
										<th>Available</th>
										<th>Start</th>
										<th>End</th>
									</tr>
								</thead>
								<tbody>
									<tr>
    <td>Monday</td>
    <td>
        <input type="checkbox"
               class="form-check-input"
               checked="@newEmployee.MondayAvailable"
               @onchange="e => { newEmployee.MondayAvailable = (bool)e.Value!; RecalculateAnytime(); }" />
    </td>
    <td>
        <input type="time" class="form-control"
               value="@FormatTime(newEmployee.MondayStart)"
               @onchange="e => { newEmployee.MondayStart = ParseTime(e.Value?.ToString()); RecalculateAnytime(); }"
               disabled="@(!newEmployee.MondayAvailable || newEmployee.IsAnytime)" />
    </td>
    <td>
        <input type="time" class="form-control"
               value="@FormatTime(newEmployee.MondayEnd)"
               @onchange="e => { newEmployee.MondayEnd = ParseTime(e.Value?.ToString()); RecalculateAnytime(); }"
               disabled="@(!newEmployee.MondayAvailable || newEmployee.IsAnytime)" />
    </td>
</tr>

									<tr>
    <td>Tuesday</td>
    <td>
        <input type="checkbox"
               class="form-check-input"
               checked="@newEmployee.TuesdayAvailable"
               @onchange="e => { newEmployee.TuesdayAvailable = (bool)e.Value!; RecalculateAnytime(); }" />
    </td>
    <td>
        <input type="time" class="form-control"
               value="@FormatTime(newEmployee.TuesdayStart)"
               @onchange="e => { newEmployee.TuesdayStart = ParseTime(e.Value?.ToString()); RecalculateAnytime(); }"
               disabled="@(!newEmployee.TuesdayAvailable || newEmployee.IsAnytime)" />
    </td>
    <td>
        <input type="time" class="form-control"
               value="@FormatTime(newEmployee.TuesdayEnd)"
               @onchange="e => { newEmployee.TuesdayEnd = ParseTime(e.Value?.ToString()); RecalculateAnytime(); }"
               disabled="@(!newEmployee.TuesdayAvailable || newEmployee.IsAnytime)" />
    </td>
</tr>

									<tr>
    <td>Wednesday</td>
    <td>
        <input type="checkbox"
               class="form-check-input"
               checked="@newEmployee.WednesdayAvailable"
               @onchange="e => { newEmployee.WednesdayAvailable = (bool)e.Value!; RecalculateAnytime(); }" />
    </td>
    <td>
        <input type="time" class="form-control"
               value="@FormatTime(newEmployee.WednesdayStart)"
               @onchange="e => { newEmployee.WednesdayStart = ParseTime(e.Value?.ToString()); RecalculateAnytime(); }"
               disabled="@(!newEmployee.WednesdayAvailable || newEmployee.IsAnytime)" />
    </td>
    <td>
        <input type="time" class="form-control"
               value="@FormatTime(newEmployee.WednesdayEnd)"
               @onchange="e => { newEmployee.WednesdayEnd = ParseTime(e.Value?.ToString()); RecalculateAnytime(); }"
               disabled="@(!newEmployee.WednesdayAvailable || newEmployee.IsAnytime)" />
    </td>
</tr>

								<tr>
    <td>Thursday</td>
    <td>
        <input type="checkbox"
               class="form-check-input"
               checked="@newEmployee.ThursdayAvailable"
               @onchange="e => { newEmployee.ThursdayAvailable = (bool)e.Value!; RecalculateAnytime(); }" />
    </td>
    <td>
        <input type="time" class="form-control"
               value="@FormatTime(newEmployee.ThursdayStart)"
               @onchange="e => { newEmployee.ThursdayStart = ParseTime(e.Value?.ToString()); RecalculateAnytime(); }"
               disabled="@(!newEmployee.ThursdayAvailable || newEmployee.IsAnytime)" />
    </td>
    <td>
        <input type="time" class="form-control"
               value="@FormatTime(newEmployee.ThursdayEnd)"
               @onchange="e => { newEmployee.ThursdayEnd = ParseTime(e.Value?.ToString()); RecalculateAnytime(); }"
               disabled="@(!newEmployee.ThursdayAvailable || newEmployee.IsAnytime)" />
    </td>
</tr>

									<tr>
    <td>Friday</td>
    <td>
        <input type="checkbox"
               class="form-check-input"
               checked="@newEmployee.FridayAvailable"
               @onchange="e => { newEmployee.FridayAvailable = (bool)e.Value!; RecalculateAnytime(); }" />
    </td>
    <td>
        <input type="time" class="form-control"
               value="@FormatTime(newEmployee.FridayStart)"
               @onchange="e => { newEmployee.FridayStart = ParseTime(e.Value?.ToString()); RecalculateAnytime(); }"
               disabled="@(!newEmployee.FridayAvailable || newEmployee.IsAnytime)" />
    </td>
    <td>
        <input type="time" class="form-control"
               value="@FormatTime(newEmployee.FridayEnd)"
               @onchange="e => { newEmployee.FridayEnd = ParseTime(e.Value?.ToString()); RecalculateAnytime(); }"
               disabled="@(!newEmployee.FridayAvailable || newEmployee.IsAnytime)" />
    </td>
</tr>

									<tr>
    <td>Saturday</td>
    <td>
        <input type="checkbox"
               class="form-check-input"
               checked="@newEmployee.SaturdayAvailable"
               @onchange="e => { newEmployee.SaturdayAvailable = (bool)e.Value!; RecalculateAnytime(); }" />
    </td>
    <td>
        <input type="time" class="form-control"
               value="@FormatTime(newEmployee.SaturdayStart)"
               @onchange="e => { newEmployee.SaturdayStart = ParseTime(e.Value?.ToString()); RecalculateAnytime(); }"
               disabled="@(!newEmployee.SaturdayAvailable || newEmployee.IsAnytime)" />
    </td>
    <td>
        <input type="time" class="form-control"
               value="@FormatTime(newEmployee.SaturdayEnd)"
               @onchange="e => { newEmployee.SaturdayEnd = ParseTime(e.Value?.ToString()); RecalculateAnytime(); }"
               disabled="@(!newEmployee.SaturdayAvailable || newEmployee.IsAnytime)" />
    </td>
</tr>

									<tr>
    <td>Sunday</td>
    <td>
        <input type="checkbox"
               class="form-check-input"
               checked="@newEmployee.SundayAvailable"
               @onchange="e => { newEmployee.SundayAvailable = (bool)e.Value!; RecalculateAnytime(); }" />
    </td>
    <td>
        <input type="time" class="form-control"
               value="@FormatTime(newEmployee.SundayStart)"
               @onchange="e => { newEmployee.SundayStart = ParseTime(e.Value?.ToString()); RecalculateAnytime(); }"
               disabled="@(!newEmployee.SundayAvailable || newEmployee.IsAnytime)" />
    </td>
    <td>
        <input type="time" class="form-control"
               value="@FormatTime(newEmployee.SundayEnd)"
               @onchange="e => { newEmployee.SundayEnd = ParseTime(e.Value?.ToString()); RecalculateAnytime(); }"
               disabled="@(!newEmployee.SundayAvailable || newEmployee.IsAnytime)" />
    </td>
</tr>
								</tbody>
							</table>
						</div>
					</div>
				</div>

			</div>

			@if (editingEmployee == null)
			{
				<button class="btn btn-primary"
						@onclick="AddEmployee"
						disabled="@isBusy">
					@(isBusy ? "Working..." : "Add Employee")
				</button>
			}
			else
			{
				<button class="btn btn-success"
						@onclick="SaveEmployee"
						disabled="@isBusy">
					@(isBusy ? "Saving..." : "Save Changes")
				</button>
			}

		</div>
	</div>

	<div class="card shadow-sm">
		<div class="card-header fw-semibold">
			Current Employees
		</div>
		@if (!string.IsNullOrWhiteSpace(deleteMessage))
		{
			<div class="alert alert-warning m-3">
				@deleteMessage
			</div>
		}
		<div class="card-body p-0">

			<ul class="list-group list-group-flush">
                @if (!employees.Any())
{
    <li class="list-group-item text-muted">
        No employees yet. Add one above 👆
    </li>
}
				@foreach (var e in employees)
				{
					<li class="list-group-item employee-item d-flex align-items-center">

    <div class="flex-grow-1 me-3">
        <div class="employee-name">@e.Name</div>

        <div class="employee-meta">
            <small>
                @e.Email |
                Max @e.MaxHoursPerWeek hrs |
                @(e.IsSalary
                    ? $"Salary: {e.WeeklySalary:C}/week"
                    : $"Hourly: {e.HourlyRate:C}/hr") |
                @e.PositionsQualified

                @if (!string.IsNullOrWhiteSpace(GetAvailabilitySummary(e)))
                {
                    <span> | @GetAvailabilitySummary(e)</span>
                }
            </small>
        </div>
    </div>  @* 👈 THIS WAS MISSING *@

    <div class="d-flex gap-2 ms-auto">
        <button class="btn btn-secondary btn-sm"
                @onclick="() => StartEdit(e)"
                disabled="@isBusy">
            Edit
        </button>

        <button class="btn btn-danger btn-sm"
                @onclick="() => DeleteEmployee(e)"
                disabled="@isBusy">
            Delete
        </button>
    </div>

</li>
				}
			</ul>
		</div>
	</div>

</div>

@code {
	private List<Position> positions = new();

	Employee? editingEmployee = null;

	private List<Employee> employees = new();

	private string? deleteMessage;

	private IEnumerable<string> ExistingPositions =>
		positions.OrderBy(p => p.Name).Select(p => p.Name);

	private Employee newEmployee = new()
	{
		MaxHoursPerWeek = 40
	};

	private bool isBusy;

	private async Task RunBusy(Func<Task> action)
	{
		if (isBusy)
			return;

		isBusy = true;
		StateHasChanged();

		try
		{
			await action();
		}
		finally
		{
			isBusy = false;
			StateHasChanged();
		}
	}

	protected override async Task OnInitializedAsync()
	{
		employees = await Schedule.GetEmployeesAsync(Schedule.Company.Id);
		positions = await Schedule.GetPositionsAsync(Schedule.Company.Id);
	}

	private void SetPayType(bool isSalary)
	{
		newEmployee.IsSalary = isSalary;
	}

	private async Task AddEmployee()
	{
		await RunBusy(async () =>
		{
			NormalizeAvailability(newEmployee);
			NormalizePay(newEmployee);

			newEmployee.CompanyId = Schedule.Company.Id;
			newEmployee.PositionsQualified = string.Join(", ", selectedPositions);

			await Schedule.AddEmployeeAsync(Schedule.Company.Id, newEmployee);

			employees = await Schedule.GetEmployeesAsync(Schedule.Company.Id);
			ClearForm();
		});
	}

	private async Task DeleteEmployee(Employee employee)
	{
		var confirmed = await JS.InvokeAsync<bool>(
			"confirm",
			$"Delete {employee.Name}?"
		);

		if (!confirmed)
			return;

		await RunBusy(async () =>
		{
			var deleted = await Schedule.DeleteEmployeeAsync(Schedule.Company.Id, employee.Id);

			if (!deleted)
			{
				deleteMessage = $"{employee.Name} cannot be deleted because they are assigned to one or more shifts.";
				return;
			}

			employees = await Schedule.GetEmployeesAsync(Schedule.Company.Id);
			deleteMessage = null;
		});
	}

	private HashSet<string> selectedPositions = new();

	private bool IsPositionSelected(string position)
	{
		return selectedPositions.Contains(position);
	}

	private void TogglePosition(string position, bool isChecked)
	{
		if (isChecked)
			selectedPositions.Add(position);
		else
			selectedPositions.Remove(position);

		newEmployee.PositionsQualified =
			string.Join(", ", selectedPositions);
	}

	async Task StartEdit(Employee emp)
	{
		editingEmployee = emp;

		newEmployee = new Employee
		{
			Id = emp.Id,
			CompanyId = emp.CompanyId,
			Name = emp.Name,
			Email = emp.Email,
			MaxHoursPerWeek = emp.MaxHoursPerWeek,
			HourlyRate = emp.HourlyRate,
			WeeklySalary = emp.WeeklySalary,
			IsSalary = emp.IsSalary,
			PositionsQualified = emp.PositionsQualified,

			MondayAvailable = emp.MondayAvailable,
			MondayAnyTime = emp.MondayAnyTime,
			MondayStart = emp.MondayStart,
			MondayEnd = emp.MondayEnd,

			TuesdayAvailable = emp.TuesdayAvailable,
			TuesdayAnyTime = emp.TuesdayAnyTime,
			TuesdayStart = emp.TuesdayStart,
			TuesdayEnd = emp.TuesdayEnd,

			WednesdayAvailable = emp.WednesdayAvailable,
			WednesdayAnyTime = emp.WednesdayAnyTime,
			WednesdayStart = emp.WednesdayStart,
			WednesdayEnd = emp.WednesdayEnd,

			ThursdayAvailable = emp.ThursdayAvailable,
			ThursdayAnyTime = emp.ThursdayAnyTime,
			ThursdayStart = emp.ThursdayStart,
			ThursdayEnd = emp.ThursdayEnd,

			FridayAvailable = emp.FridayAvailable,
			FridayAnyTime = emp.FridayAnyTime,
			FridayStart = emp.FridayStart,
			FridayEnd = emp.FridayEnd,

			SaturdayAvailable = emp.SaturdayAvailable,
			SaturdayAnyTime = emp.SaturdayAnyTime,
			SaturdayStart = emp.SaturdayStart,
			SaturdayEnd = emp.SaturdayEnd,

			SundayAvailable = emp.SundayAvailable,
			SundayAnyTime = emp.SundayAnyTime,
			SundayStart = emp.SundayStart,
			SundayEnd = emp.SundayEnd
		};

  RecalculateAnytime();

		selectedPositions = emp.PositionsQualified
			.Split(',', StringSplitOptions.RemoveEmptyEntries)
			.Select(p => p.Trim())
			.ToHashSet();

		await Task.Yield();
		await JS.InvokeVoidAsync("scrollToElement", "employee-form");
	}

	private async Task SaveEmployee()
	{
		await RunBusy(async () =>
		{
			if (editingEmployee == null)
				return;

			NormalizeAvailability(newEmployee);
			NormalizePay(newEmployee);
			newEmployee.PositionsQualified = string.Join(", ", selectedPositions);

			await Schedule.UpdateEmployeeAsync(Schedule.Company.Id, newEmployee);

			employees = await Schedule.GetEmployeesAsync(Schedule.Company.Id);

			editingEmployee = null;
			ClearForm();
		});
	}

	void ClearForm()
	{
		newEmployee = new Employee
		{
			MaxHoursPerWeek = 40,
			IsSalary = false,
			HourlyRate = null,
			WeeklySalary = null
		};

		selectedPositions.Clear();
	}

	private void NormalizePay(Employee e)
	{
		if (e.IsSalary)
		{
			e.HourlyRate = null;
		}
		else
		{
			e.WeeklySalary = null;
		}
	}

	private static string FormatTime(TimeSpan? time)
	{
		return time.HasValue ? time.Value.ToString(@"hh\:mm") : "";
	}

	private static TimeSpan? ParseTime(string? value)
	{
		if (TimeSpan.TryParse(value, out var result))
			return result;

		return null;
	}

	string GetAvailabilitySummary(Employee e)
	{
		var parts = new List<string>();

		AddDay(parts, "Mon", e.MondayAvailable, e.MondayAnyTime, e.MondayStart, e.MondayEnd);
		AddDay(parts, "Tue", e.TuesdayAvailable, e.TuesdayAnyTime, e.TuesdayStart, e.TuesdayEnd);
		AddDay(parts, "Wed", e.WednesdayAvailable, e.WednesdayAnyTime, e.WednesdayStart, e.WednesdayEnd);
		AddDay(parts, "Thu", e.ThursdayAvailable, e.ThursdayAnyTime, e.ThursdayStart, e.ThursdayEnd);
		AddDay(parts, "Fri", e.FridayAvailable, e.FridayAnyTime, e.FridayStart, e.FridayEnd);
		AddDay(parts, "Sat", e.SaturdayAvailable, e.SaturdayAnyTime, e.SaturdayStart, e.SaturdayEnd);
		AddDay(parts, "Sun", e.SundayAvailable, e.SundayAnyTime, e.SundayStart, e.SundayEnd);

		return parts.Count > 0 ? string.Join(" | ", parts) : "Unavailable";
	}

	void AddDay(List<string> parts, string day, bool available, bool anyTime, TimeSpan? start, TimeSpan? end)
	{
		if (!available)
			return;

		if (anyTime || (!start.HasValue && !end.HasValue))
		{
			parts.Add($"{day}: AnyTime");
		}
		else if (start.HasValue && end.HasValue)
		{
			parts.Add($"{day}: {DateTime.Today.Add(start.Value):h:mm tt} - {DateTime.Today.Add(end.Value):h:mm tt}");
		}
		else
		{
			parts.Add($"{day}: AnyTime");
		}
	}

	private string FormatDisplayTime(TimeSpan time)
	{
		return DateTime.Today.Add(time).ToString("h:mmtt").ToLower();
	}

	private void AddAvailabilityPart(List<string> parts, string dayLabel, bool available, TimeSpan? start, TimeSpan? end)
	{
		if (!available)
			return;

		if (start.HasValue && end.HasValue)
		{
			parts.Add($"{dayLabel} {FormatDisplayTime(start.Value)}-{FormatDisplayTime(end.Value)}");
		}
		else
		{
			parts.Add($"{dayLabel} Available");
		}
	}

	private void NormalizeAvailability(Employee e)
{
    if (e.IsAnytime)
    {
        e.MondayAvailable = true;
        e.TuesdayAvailable = true;
        e.WednesdayAvailable = true;
        e.ThursdayAvailable = true;
        e.FridayAvailable = true;
        e.SaturdayAvailable = true;
        e.SundayAvailable = true;

        e.MondayStart = e.TuesdayStart = e.WednesdayStart =
        e.ThursdayStart = e.FridayStart = e.SaturdayStart =
        e.SundayStart = null;

        e.MondayEnd = e.TuesdayEnd = e.WednesdayEnd =
        e.ThursdayEnd = e.FridayEnd = e.SaturdayEnd =
        e.SundayEnd = null;

        return;
    }

    NormalizeDay(
    e.MondayAvailable,
    e.MondayStart,
    e.MondayEnd,
    (available, start, end) =>
    {
        e.MondayAvailable = available;
        e.MondayStart = start;
        e.MondayEnd = end;
    });
    NormalizeDay(
    e.TuesdayAvailable,
    e.TuesdayStart,
    e.TuesdayEnd,
    (available, start, end) =>
    {
        e.TuesdayAvailable = available;
        e.TuesdayStart = start;
        e.TuesdayEnd = end;
    });
    NormalizeDay(
    e.WednesdayAvailable,
    e.WednesdayStart,
    e.WednesdayEnd,
    (available, start, end) =>
    {
        e.WednesdayAvailable = available;
        e.WednesdayStart = start;
        e.WednesdayEnd = end;
    });
    NormalizeDay(
    e.ThursdayAvailable,
    e.ThursdayStart,
    e.ThursdayEnd,
    (available, start, end) =>
    {
        e.ThursdayAvailable = available;
        e.ThursdayStart = start;
        e.ThursdayEnd = end;
    });
    NormalizeDay(
    e.FridayAvailable,
    e.FridayStart,
    e.FridayEnd,
    (available, start, end) =>
    {
        e.FridayAvailable = available;
        e.FridayStart = start;
        e.FridayEnd = end;
    });
    NormalizeDay(
    e.SaturdayAvailable,
    e.SaturdayStart,
    e.SaturdayEnd,
    (available, start, end) =>
    {
        e.SaturdayAvailable = available;
        e.SaturdayStart = start;
        e.SaturdayEnd = end;
    });
    NormalizeDay(
    e.SundayAvailable,
    e.SundayStart,
    e.SundayEnd,
    (available, start, end) =>
    {
        e.SundayAvailable = available;
        e.SundayStart = start;
        e.SundayEnd = end;
    });
}

	

	private void NormalizeDay(
    bool available,
    TimeSpan? start,
    TimeSpan? end,
    Action<bool, TimeSpan?, TimeSpan?> apply)
{
    if (!available)
    {
        apply(false, null, null);
        return;
    }

    if (!start.HasValue || !end.HasValue)
    {
        apply(true, null, null);
        return;
    }

    apply(true, start, end);
}

void RecalculateAnytime()
{
    newEmployee.IsAnytime =
        newEmployee.MondayAvailable && !newEmployee.MondayStart.HasValue && !newEmployee.MondayEnd.HasValue &&
        newEmployee.TuesdayAvailable && !newEmployee.TuesdayStart.HasValue && !newEmployee.TuesdayEnd.HasValue &&
        newEmployee.WednesdayAvailable && !newEmployee.WednesdayStart.HasValue && !newEmployee.WednesdayEnd.HasValue &&
        newEmployee.ThursdayAvailable && !newEmployee.ThursdayStart.HasValue && !newEmployee.ThursdayEnd.HasValue &&
        newEmployee.FridayAvailable && !newEmployee.FridayStart.HasValue && !newEmployee.FridayEnd.HasValue &&
        newEmployee.SaturdayAvailable && !newEmployee.SaturdayStart.HasValue && !newEmployee.SaturdayEnd.HasValue &&
        newEmployee.SundayAvailable && !newEmployee.SundayStart.HasValue && !newEmployee.SundayEnd.HasValue;
}

void ToggleAnytime(bool isOn)
{
    if (isOn)
    {
        newEmployee.MondayAvailable =
        newEmployee.TuesdayAvailable =
        newEmployee.WednesdayAvailable =
        newEmployee.ThursdayAvailable =
        newEmployee.FridayAvailable =
        newEmployee.SaturdayAvailable =
        newEmployee.SundayAvailable = true;

        newEmployee.MondayStart =
        newEmployee.TuesdayStart =
        newEmployee.WednesdayStart =
        newEmployee.ThursdayStart =
        newEmployee.FridayStart =
        newEmployee.SaturdayStart =
        newEmployee.SundayStart = null;

        newEmployee.MondayEnd =
        newEmployee.TuesdayEnd =
        newEmployee.WednesdayEnd =
        newEmployee.ThursdayEnd =
        newEmployee.FridayEnd =
        newEmployee.SaturdayEnd =
        newEmployee.SundayEnd = null;
    }
    else
    {
        newEmployee.MondayAvailable =
        newEmployee.TuesdayAvailable =
        newEmployee.WednesdayAvailable =
        newEmployee.ThursdayAvailable =
        newEmployee.FridayAvailable =
        newEmployee.SaturdayAvailable =
        newEmployee.SundayAvailable = false;
    }

    RecalculateAnytime();
}   
}
