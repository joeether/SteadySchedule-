@page "/employees"
@using SteadySchedule.Domain
@using SteadySchedule.Services
@inject ScheduleService Schedule

<PageTitle>Employees</PageTitle>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Employees</h2>
        <span class="badge bg-dark">Company: Mama's Burger Joint</span>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header fw-semibold">
            Add Employee
        </div>
        <div class="card-body">

            <div class="row g-3">

                <div class="col-md-4">
                    <label class="form-label">Name</label>
                    <input class="form-control" @bind="newEmployee.Name" />
                </div>

                <div class="col-md-4">
                    <label class="form-label">Email</label>
                    <input class="form-control" @bind="newEmployee.Email" />
                </div>

                <div class="col-md-4">
                    <label class="form-label">Max Hours / Week</label>
                    <input type="number" class="form-control" @bind="newEmployee.MaxHoursPerWeek" />
                </div>

                <div class="col-12">
                    <label class="form-label">Positions Qualified</label>

                    @foreach (var position in ExistingPositions)
                    {
                        <div class="form-check">
                            <input class="form-check-input"
                                   type="checkbox"
                                   checked="@IsPositionSelected(position)"
                                   @onchange="(e) => TogglePosition(position, (bool)e.Value!)" />

                            <label class="form-check-label">
                                @position
                            </label>
                        </div>
                    }

                    <div class="col-12">
                        <label class="form-label fw-semibold">Availability</label>

                        <div class="table-responsive">
                            <table class="table table-sm align-middle">
                                <thead>
                                    <tr>
                                        <th>Day</th>
                                        <th>Available</th>
                                        <th>Start</th>
                                        <th>End</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>Monday</td>
                                        <td><input type="checkbox" class="form-check-input" @bind="newEmployee.MondayAvailable" /></td>
                                        <td>
                                            <input type="time" class="form-control"
                                                   value="@FormatTime(newEmployee.MondayStart)"
                                                   @onchange="e => newEmployee.MondayStart = ParseTime(e.Value?.ToString())"
                                                   disabled="@(!newEmployee.MondayAvailable)" />
                                        </td>
                                        <td>
                                            <input type="time" class="form-control"
                                                   value="@FormatTime(newEmployee.MondayEnd)"
                                                   @onchange="e => newEmployee.MondayEnd = ParseTime(e.Value?.ToString())"
                                                   disabled="@(!newEmployee.MondayAvailable)" />
                                        </td>
                                    </tr>

                                    <tr>
                                        <td>Tuesday</td>
                                        <td><input type="checkbox" class="form-check-input" @bind="newEmployee.TuesdayAvailable" /></td>
                                        <td>
                                            <input type="time" class="form-control"
                                                   value="@FormatTime(newEmployee.TuesdayStart)"
                                                   @onchange="e => newEmployee.TuesdayStart = ParseTime(e.Value?.ToString())"
                                                   disabled="@(!newEmployee.TuesdayAvailable)" />
                                        </td>
                                        <td>
                                            <input type="time" class="form-control"
                                                   value="@FormatTime(newEmployee.TuesdayEnd)"
                                                   @onchange="e => newEmployee.TuesdayEnd = ParseTime(e.Value?.ToString())"
                                                   disabled="@(!newEmployee.TuesdayAvailable)" />
                                        </td>
                                    </tr>

                                    <tr>
                                        <td>Wednesday</td>
                                        <td><input type="checkbox" class="form-check-input" @bind="newEmployee.WednesdayAvailable" /></td>
                                        <td>
                                            <input type="time" class="form-control"
                                                   value="@FormatTime(newEmployee.WednesdayStart)"
                                                   @onchange="e => newEmployee.WednesdayStart = ParseTime(e.Value?.ToString())"
                                                   disabled="@(!newEmployee.WednesdayAvailable)" />
                                        </td>
                                        <td>
                                            <input type="time" class="form-control"
                                                   value="@FormatTime(newEmployee.WednesdayEnd)"
                                                   @onchange="e => newEmployee.WednesdayEnd = ParseTime(e.Value?.ToString())"
                                                   disabled="@(!newEmployee.WednesdayAvailable)" />
                                        </td>
                                    </tr>

                                    <tr>
                                        <td>Thursday</td>
                                        <td><input type="checkbox" class="form-check-input" @bind="newEmployee.ThursdayAvailable" /></td>
                                        <td>
                                            <input type="time" class="form-control"
                                                   value="@FormatTime(newEmployee.ThursdayStart)"
                                                   @onchange="e => newEmployee.ThursdayStart = ParseTime(e.Value?.ToString())"
                                                   disabled="@(!newEmployee.ThursdayAvailable)" />
                                        </td>
                                        <td>
                                            <input type="time" class="form-control"
                                                   value="@FormatTime(newEmployee.ThursdayEnd)"
                                                   @onchange="e => newEmployee.ThursdayEnd = ParseTime(e.Value?.ToString())"
                                                   disabled="@(!newEmployee.ThursdayAvailable)" />
                                        </td>
                                    </tr>

                                    <tr>
                                        <td>Friday</td>
                                        <td><input type="checkbox" class="form-check-input" @bind="newEmployee.FridayAvailable" /></td>
                                        <td>
                                            <input type="time" class="form-control"
                                                   value="@FormatTime(newEmployee.FridayStart)"
                                                   @onchange="e => newEmployee.FridayStart = ParseTime(e.Value?.ToString())"
                                                   disabled="@(!newEmployee.FridayAvailable)" />
                                        </td>
                                        <td>
                                            <input type="time" class="form-control"
                                                   value="@FormatTime(newEmployee.FridayEnd)"
                                                   @onchange="e => newEmployee.FridayEnd = ParseTime(e.Value?.ToString())"
                                                   disabled="@(!newEmployee.FridayAvailable)" />
                                        </td>
                                    </tr>

                                    <tr>
                                        <td>Saturday</td>
                                        <td><input type="checkbox" class="form-check-input" @bind="newEmployee.SaturdayAvailable" /></td>
                                        <td>
                                            <input type="time" class="form-control"
                                                   value="@FormatTime(newEmployee.SaturdayStart)"
                                                   @onchange="e => newEmployee.SaturdayStart = ParseTime(e.Value?.ToString())"
                                                   disabled="@(!newEmployee.SaturdayAvailable)" />
                                        </td>
                                        <td>
                                            <input type="time" class="form-control"
                                                   value="@FormatTime(newEmployee.SaturdayEnd)"
                                                   @onchange="e => newEmployee.SaturdayEnd = ParseTime(e.Value?.ToString())"
                                                   disabled="@(!newEmployee.SaturdayAvailable)" />
                                        </td>
                                    </tr>

                                    <tr>
                                        <td>Sunday</td>
                                        <td><input type="checkbox" class="form-check-input" @bind="newEmployee.SundayAvailable" /></td>
                                        <td>
                                            <input type="time" class="form-control"
                                                   value="@FormatTime(newEmployee.SundayStart)"
                                                   @onchange="e => newEmployee.SundayStart = ParseTime(e.Value?.ToString())"
                                                   disabled="@(!newEmployee.SundayAvailable)" />
                                        </td>
                                        <td>
                                            <input type="time" class="form-control"
                                                   value="@FormatTime(newEmployee.SundayEnd)"
                                                   @onchange="e => newEmployee.SundayEnd = ParseTime(e.Value?.ToString())"
                                                   disabled="@(!newEmployee.SundayAvailable)" />
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

            </div>

            @if (editingEmployee == null)
            {
                <button class="btn btn-primary" @onclick="AddEmployee">
                    Add Employee
                </button>
            }
            else
            {
                <button class="btn btn-success" @onclick="SaveEmployee">
                    Save Changes
                </button>
            }

        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header fw-semibold">
            Current Employees
        </div>
        @if (!string.IsNullOrWhiteSpace(deleteMessage))
        {
            <div class="alert alert-warning m-3">
                @deleteMessage
            </div>
        }
        <div class="card-body p-0">
            
            <ul class="list-group list-group-flush">
                @foreach (var e in employees)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">

                        <div>
                            <div class="fw-semibold">@e.Name</div>
                            <small>
                                @e.Email |
                                Max @e.MaxHoursPerWeek hrs |
                                @e.PositionsQualified
                                @if (!string.IsNullOrWhiteSpace(GetAvailabilitySummary(e)))
                                {
                                    <span> | @GetAvailabilitySummary(e)</span>
                                }
                            </small>
                        </div>

                        <button class="btn btn-secondary btn-sm me-2"
                                @onclick="() => StartEdit(e)">
                            Edit
                        </button>

                        <button class="btn btn-danger btn-sm"
                                @onclick="() => DeleteEmployee(e)">
                            Delete
                        </button>

                    </li>
                }
            </ul>
        </div>
    </div>

</div>

@code {

    Employee? editingEmployee = null;

    private List<Employee> employees => Schedule.Employees;

    private string? deleteMessage;

    private IEnumerable<string> ExistingPositions =>
    Schedule.Positions.OrderBy(p => p);

    private Employee newEmployee = new()
    {
        CompanyId = 1,
        MaxHoursPerWeek = 40
    };

    private void AddEmployee()
    {
        newEmployee.Id = employees.Count + 1;
        newEmployee.PositionsQualified = string.Join(", ", selectedPositions);

        employees.Add(newEmployee);

        ClearForm();
    }

    private void DeleteEmployee(Employee employee)
    {
        var hasAssignments = Schedule.Assignments
            .Any(a => a.EmployeeId == employee.Id);

        if (hasAssignments)
        {
            deleteMessage = $"{employee.Name} cannot be deleted because they are assigned to one or more shifts.";
            return;
        }

        Schedule.Employees.Remove(employee);
        deleteMessage = null;
    }

    private HashSet<string> selectedPositions = new();

    private bool IsPositionSelected(string position)
    {
        return selectedPositions.Contains(position);
    }

    private void TogglePosition(string position, bool isChecked)
    {
        if (isChecked)
            selectedPositions.Add(position);
        else
            selectedPositions.Remove(position);

        newEmployee.PositionsQualified =
            string.Join(", ", selectedPositions);
    }

    void StartEdit(Employee emp)
    {
        editingEmployee = emp;

        newEmployee = new Employee
        {
            Id = emp.Id,
            CompanyId = emp.CompanyId,
            Name = emp.Name,
            Email = emp.Email,
            MaxHoursPerWeek = emp.MaxHoursPerWeek,
            PositionsQualified = emp.PositionsQualified,

            MondayAvailable = emp.MondayAvailable,
            MondayStart = emp.MondayStart,
            MondayEnd = emp.MondayEnd,

            TuesdayAvailable = emp.TuesdayAvailable,
            TuesdayStart = emp.TuesdayStart,
            TuesdayEnd = emp.TuesdayEnd,

            WednesdayAvailable = emp.WednesdayAvailable,
            WednesdayStart = emp.WednesdayStart,
            WednesdayEnd = emp.WednesdayEnd,

            ThursdayAvailable = emp.ThursdayAvailable,
            ThursdayStart = emp.ThursdayStart,
            ThursdayEnd = emp.ThursdayEnd,

            FridayAvailable = emp.FridayAvailable,
            FridayStart = emp.FridayStart,
            FridayEnd = emp.FridayEnd,

            SaturdayAvailable = emp.SaturdayAvailable,
            SaturdayStart = emp.SaturdayStart,
            SaturdayEnd = emp.SaturdayEnd,

            SundayAvailable = emp.SundayAvailable,
            SundayStart = emp.SundayStart,
            SundayEnd = emp.SundayEnd
        };

        selectedPositions = new HashSet<string>(
            emp.PositionsQualified?.Split(", ", StringSplitOptions.RemoveEmptyEntries)
            ?? Array.Empty<string>()
        );
    }

    void SaveEmployee()
    {
        if (editingEmployee == null)
            return;

        editingEmployee.Name = newEmployee.Name;
        editingEmployee.Email = newEmployee.Email;
        editingEmployee.MaxHoursPerWeek = newEmployee.MaxHoursPerWeek;
        editingEmployee.PositionsQualified = string.Join(", ", selectedPositions);

        editingEmployee.MondayAvailable = newEmployee.MondayAvailable;
        editingEmployee.MondayStart = newEmployee.MondayStart;
        editingEmployee.MondayEnd = newEmployee.MondayEnd;

        editingEmployee.TuesdayAvailable = newEmployee.TuesdayAvailable;
        editingEmployee.TuesdayStart = newEmployee.TuesdayStart;
        editingEmployee.TuesdayEnd = newEmployee.TuesdayEnd;

        editingEmployee.WednesdayAvailable = newEmployee.WednesdayAvailable;
        editingEmployee.WednesdayStart = newEmployee.WednesdayStart;
        editingEmployee.WednesdayEnd = newEmployee.WednesdayEnd;

        editingEmployee.ThursdayAvailable = newEmployee.ThursdayAvailable;
        editingEmployee.ThursdayStart = newEmployee.ThursdayStart;
        editingEmployee.ThursdayEnd = newEmployee.ThursdayEnd;

        editingEmployee.FridayAvailable = newEmployee.FridayAvailable;
        editingEmployee.FridayStart = newEmployee.FridayStart;
        editingEmployee.FridayEnd = newEmployee.FridayEnd;

        editingEmployee.SaturdayAvailable = newEmployee.SaturdayAvailable;
        editingEmployee.SaturdayStart = newEmployee.SaturdayStart;
        editingEmployee.SaturdayEnd = newEmployee.SaturdayEnd;

        editingEmployee.SundayAvailable = newEmployee.SundayAvailable;
        editingEmployee.SundayStart = newEmployee.SundayStart;
        editingEmployee.SundayEnd = newEmployee.SundayEnd;

        editingEmployee = null;
        ClearForm();
    }

    void ClearForm()
    {
        newEmployee = new Employee
        {
            CompanyId = 1,
            MaxHoursPerWeek = 40
        };

        selectedPositions.Clear();
    }

    private static string FormatTime(TimeSpan? time)
    {
        return time.HasValue ? time.Value.ToString(@"hh\:mm") : "";
    }

    private static TimeSpan? ParseTime(string? value)
    {
        if (TimeSpan.TryParse(value, out var result))
            return result;

        return null;
    }

    private string GetAvailabilitySummary(Employee e)
    {
        var days = new List<(string Label, bool Available, TimeSpan? Start, TimeSpan? End)>
    {
        ("Mon", e.MondayAvailable, e.MondayStart, e.MondayEnd),
        ("Tue", e.TuesdayAvailable, e.TuesdayStart, e.TuesdayEnd),
        ("Wed", e.WednesdayAvailable, e.WednesdayStart, e.WednesdayEnd),
        ("Thu", e.ThursdayAvailable, e.ThursdayStart, e.ThursdayEnd),
        ("Fri", e.FridayAvailable, e.FridayStart, e.FridayEnd),
        ("Sat", e.SaturdayAvailable, e.SaturdayStart, e.SaturdayEnd),
        ("Sun", e.SundayAvailable, e.SundayStart, e.SundayEnd)
    };

        var parts = new List<string>();
        int i = 0;

        while (i < days.Count)
        {
            var day = days[i];

            if (!day.Available)
            {
                i++;
                continue;
            }

            int startIndex = i;
            int endIndex = i;

            while (endIndex + 1 < days.Count &&
                   days[endIndex + 1].Available &&
                   days[endIndex + 1].Start == day.Start &&
                   days[endIndex + 1].End == day.End)
            {
                endIndex++;
            }

            var dayLabel = startIndex == endIndex
                ? days[startIndex].Label
                : $"{days[startIndex].Label}-{days[endIndex].Label}";

            if (day.Start.HasValue && day.End.HasValue)
            {
                parts.Add($"{dayLabel} {FormatDisplayTime(day.Start.Value)}-{FormatDisplayTime(day.End.Value)}");
            }
            else
            {
                parts.Add($"{dayLabel} Available");
            }

            i = endIndex + 1;
        }

        return string.Join(" | ", parts);
    }

    private string FormatDisplayTime(TimeSpan time)
    {
        return DateTime.Today.Add(time).ToString("h:mmtt").ToLower();
    }

    private void AddAvailabilityPart(List<string> parts, string dayLabel, bool available, TimeSpan? start, TimeSpan? end)
    {
        if (!available)
            return;

        if (start.HasValue && end.HasValue)
        {
            parts.Add($"{dayLabel} {FormatDisplayTime(start.Value)}-{FormatDisplayTime(end.Value)}");
        }
        else
        {
            parts.Add($"{dayLabel} Available");
        }
    }
}