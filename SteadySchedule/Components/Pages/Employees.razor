@page "/employees"
@using SteadySchedule.Domain
@using SteadySchedule.Services
@inject ScheduleService Schedule
@inject IJSRuntime JS

<PageTitle>Employees</PageTitle>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Employees</h2>
        <span class="badge bg-dark">Company: Mama's Burger Joint</span>
    </div>

    <div id="employee-form" class="card shadow-sm mb-4">
        <div class="card-header fw-semibold">
            Add Employee
        </div>
        <div class="card-body">

            <div class="row g-3">

                <div class="col-md-4">
                    <label class="form-label">Name</label>
                    <input class="form-control" @bind="newEmployee.Name" />
                </div>

                <div class="col-md-4">
                    <label class="form-label">Email</label>
                    <input class="form-control" @bind="newEmployee.Email" />
                </div>

                <div class="col-md-4">
                    <label class="form-label">Max Hours / Week</label>
                    <input type="number" class="form-control" @bind="newEmployee.MaxHoursPerWeek" />
                </div>

                <div class="col-12">
                    <label class="form-label">Jobs They Can Work</label>

                    @foreach (var position in ExistingPositions)
                    {
                        <div class="form-check">
                            <input class="form-check-input"
                                   type="checkbox"
                                   checked="@IsPositionSelected(position)"
                                   @onchange="(e) => TogglePosition(position, (bool)e.Value!)" />

                            <label class="form-check-label">
                                @position
                            </label>
                        </div>
                    }

                    <div class="col-12">
                        <label class="form-label fw-semibold">Availability</label>

                        <div class="table-responsive">
                            <table class="table table-sm align-middle">
                                <thead>
                                    <tr>
                                        <th>Day</th>
                                        <th>Available</th>
                                        <th>Any Time</th>
                                        <th>Start</th>
                                        <th>End</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>Monday</td>
                                        <td>
                                            <input type="checkbox"
                                                   class="form-check-input"
                                                   @bind="newEmployee.MondayAvailable" />
                                        </td>
                                        <td>
                                            <input type="checkbox"
                                                   class="form-check-input"
                                                   checked="@newEmployee.MondayAnyTime"
                                                   @onchange="e => OnMondayAnyTimeChanged((bool)e.Value!)"
                                                   disabled="@(!newEmployee.MondayAvailable)" />
                                        </td>
                                        <td>
                                            <input type="time" class="form-control"
                                                   value="@FormatTime(newEmployee.MondayStart)"
                                                   @onchange="e => newEmployee.MondayStart = ParseTime(e.Value?.ToString())"
                                                   disabled="@(!newEmployee.MondayAvailable || newEmployee.MondayAnyTime)" />
                                        </td>
                                        <td>
                                            <input type="time" class="form-control"
                                                   value="@FormatTime(newEmployee.MondayEnd)"
                                                   @onchange="e => newEmployee.MondayEnd = ParseTime(e.Value?.ToString())"
                                                   disabled="@(!newEmployee.MondayAvailable || newEmployee.MondayAnyTime)" />
                                        </td>
                                    </tr>

                                    <tr>
                                        <td>Tuesday</td>
                                        <td><input type="checkbox" class="form-check-input" @bind="newEmployee.TuesdayAvailable" /></td>
                                        <td>
                                            <input type="checkbox"
                                                   class="form-check-input"
                                                   checked="@newEmployee.TuesdayAnyTime"
                                                   @onchange="e => OnTuesdayAnyTimeChanged((bool)e.Value!)"
                                                   disabled="@(!newEmployee.TuesdayAvailable)" />
                                        </td>
                                        <td>
                                            <input type="time" class="form-control"
                                                   value="@FormatTime(newEmployee.TuesdayStart)"
                                                   @onchange="e => newEmployee.TuesdayStart = ParseTime(e.Value?.ToString())"
                                                   disabled="@(!newEmployee.TuesdayAvailable || newEmployee.TuesdayAnyTime)" />
                                        </td>
                                        <td>
                                            <input type="time" class="form-control"
                                                   value="@FormatTime(newEmployee.TuesdayEnd)"
                                                   @onchange="e => newEmployee.TuesdayEnd = ParseTime(e.Value?.ToString())"
                                                   disabled="@(!newEmployee.TuesdayAvailable || newEmployee.TuesdayAnyTime)" />
                                        </td>
                                    </tr>

                                    <tr>
                                        <td>Wednesday</td>
                                        <td><input type="checkbox" class="form-check-input" @bind="newEmployee.WednesdayAvailable" /></td>
                                        <td>
                                            <input type="checkbox"
                                                   class="form-check-input"
                                                   checked="@newEmployee.WednesdayAnyTime"
                                                   @onchange="e => OnWednesdayAnyTimeChanged((bool)e.Value!)"
                                                   disabled="@(!newEmployee.WednesdayAvailable)" />
                                        </td>
                                        <td>
                                            <input type="time" class="form-control"
                                                   value="@FormatTime(newEmployee.WednesdayStart)"
                                                   @onchange="e => newEmployee.WednesdayStart = ParseTime(e.Value?.ToString())"
                                                   disabled="@(!newEmployee.WednesdayAvailable || newEmployee.WednesdayAnyTime)" />
                                        </td>
                                        <td>
                                            <input type="time" class="form-control"
                                                   value="@FormatTime(newEmployee.WednesdayEnd)"
                                                   @onchange="e => newEmployee.WednesdayEnd = ParseTime(e.Value?.ToString())"
                                                   disabled="@(!newEmployee.WednesdayAvailable || newEmployee.WednesdayAnyTime)" />
                                        </td>
                                    </tr>

                                    <tr>
                                        <td>Thursday</td>
                                        <td><input type="checkbox" class="form-check-input" @bind="newEmployee.ThursdayAvailable" /></td>
                                        <td>
                                            <input type="checkbox"
                                                   class="form-check-input"
                                                   checked="@newEmployee.ThursdayAnyTime"
                                                   @onchange="e => OnThursdayAnyTimeChanged((bool)e.Value!)"
                                                   disabled="@(!newEmployee.ThursdayAvailable)" />
                                        </td>
                                        <td>
                                            <input type="time" class="form-control"
                                                   value="@FormatTime(newEmployee.ThursdayStart)"
                                                   @onchange="e => newEmployee.ThursdayStart = ParseTime(e.Value?.ToString())"
                                                   disabled="@(!newEmployee.ThursdayAvailable || newEmployee.ThursdayAnyTime)" />
                                        </td>
                                        <td>
                                            <input type="time" class="form-control"
                                                   value="@FormatTime(newEmployee.ThursdayEnd)"
                                                   @onchange="e => newEmployee.ThursdayEnd = ParseTime(e.Value?.ToString())"
                                                   disabled="@(!newEmployee.ThursdayAvailable || newEmployee.ThursdayAnyTime)" />
                                        </td>
                                    </tr>

                                    <tr>
                                        <td>Friday</td>
                                        <td><input type="checkbox" class="form-check-input" @bind="newEmployee.FridayAvailable" /></td>
                                        <td>
                                            <input type="checkbox"
                                                   class="form-check-input"
                                                   checked="@newEmployee.FridayAnyTime"
                                                   @onchange="e => OnFridayAnyTimeChanged((bool)e.Value!)"
                                                   disabled="@(!newEmployee.FridayAvailable)" />
                                        </td>
                                        <td>
                                            <input type="time" class="form-control"
                                                   value="@FormatTime(newEmployee.FridayStart)"
                                                   @onchange="e => newEmployee.FridayStart = ParseTime(e.Value?.ToString())"
                                                   disabled="@(!newEmployee.FridayAvailable || newEmployee.FridayAnyTime)" />
                                        </td>
                                        <td>
                                            <input type="time" class="form-control"
                                                   value="@FormatTime(newEmployee.FridayEnd)"
                                                   @onchange="e => newEmployee.FridayEnd = ParseTime(e.Value?.ToString())"
                                                   disabled="@(!newEmployee.FridayAvailable || newEmployee.FridayAnyTime)" />
                                        </td>
                                    </tr>

                                    <tr>
                                        <td>Saturday</td>
                                        <td><input type="checkbox" class="form-check-input" @bind="newEmployee.SaturdayAvailable" /></td>
                                        <td>
                                            <input type="checkbox"
                                                   class="form-check-input"
                                                   checked="@newEmployee.SaturdayAnyTime"
                                                   @onchange="e => OnSaturdayAnyTimeChanged((bool)e.Value!)"
                                                   disabled="@(!newEmployee.SaturdayAvailable)" />
                                        </td>
                                        <td>
                                            <input type="time" class="form-control"
                                                   value="@FormatTime(newEmployee.SaturdayStart)"
                                                   @onchange="e => newEmployee.SaturdayStart = ParseTime(e.Value?.ToString())"
                                                   disabled="@(!newEmployee.SaturdayAvailable || newEmployee.SaturdayAnyTime)" />
                                        </td>
                                        <td>
                                            <input type="time" class="form-control"
                                                   value="@FormatTime(newEmployee.SaturdayEnd)"
                                                   @onchange="e => newEmployee.SaturdayEnd = ParseTime(e.Value?.ToString())"
                                                   disabled="@(!newEmployee.SaturdayAvailable || newEmployee.SaturdayAnyTime)" />
                                        </td>
                                    </tr>

                                    <tr>
                                        <td>Sunday</td>
                                        <td><input type="checkbox" class="form-check-input" @bind="newEmployee.SundayAvailable" /></td>
                                        <td>
                                            <input type="checkbox"
                                                   class="form-check-input"
                                                   checked="@newEmployee.SundayAnyTime"
                                                   @onchange="e => OnSundayAnyTimeChanged((bool)e.Value!)"
                                                   disabled="@(!newEmployee.SundayAvailable)" />
                                        </td>
                                        <td>
                                            <input type="time" class="form-control"
                                                   value="@FormatTime(newEmployee.SundayStart)"
                                                   @onchange="e => newEmployee.SundayStart = ParseTime(e.Value?.ToString())"
                                                   disabled="@(!newEmployee.SundayAvailable || newEmployee.SundayAnyTime)" />
                                        </td>
                                        <td>
                                            <input type="time" class="form-control"
                                                   value="@FormatTime(newEmployee.SundayEnd)"
                                                   @onchange="e => newEmployee.SundayEnd = ParseTime(e.Value?.ToString())"
                                                   disabled="@(!newEmployee.SundayAvailable || newEmployee.SundayAnyTime)" />
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

            </div>

            @if (editingEmployee == null)
            {
                <button class="btn btn-primary" @onclick="AddEmployee">
                    Add Employee
                </button>
            }
            else
            {
                <button class="btn btn-success" @onclick="SaveEmployee">
                    Save Changes
                </button>
            }

        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header fw-semibold">
            Current Employees
        </div>
        @if (!string.IsNullOrWhiteSpace(deleteMessage))
        {
            <div class="alert alert-warning m-3">
                @deleteMessage
            </div>
        }
        <div class="card-body p-0">
            
            <ul class="list-group list-group-flush">
                @foreach (var e in employees)
                {
                    <li class="list-group-item d-flex align-items-center">

                        <div class="flex-grow-1 me-3">
                            <div class="fw-semibold">@e.Name</div>
                            <small>
                                @e.Email |
                                Max @e.MaxHoursPerWeek hrs |
                                @e.PositionsQualified
                                @if (!string.IsNullOrWhiteSpace(GetAvailabilitySummary(e)))
                                {
                                    <span> | @GetAvailabilitySummary(e)</span>
                                }
                            </small>
                        </div>

                        <div class="d-flex gap-2 ms-auto">
                            <button class="btn btn-secondary btn-sm"
                                    @onclick="() => StartEdit(e)">
                                Edit
                            </button>

                            <button class="btn btn-danger btn-sm"
                                    @onclick="() => DeleteEmployee(e)">
                                Delete
                            </button>
                        </div>

                    </li>
                }
            </ul>
        </div>
    </div>

</div>

@code {

    Employee? editingEmployee = null;

    private List<Employee> employees => Schedule.Employees;

    private string? deleteMessage;

    private IEnumerable<string> ExistingPositions =>
    Schedule.Positions.OrderBy(p => p);

    private Employee newEmployee = new()
    {
        CompanyId = 1,
        MaxHoursPerWeek = 40
    };

    private void AddEmployee()
    {
        NormalizeAvailability(newEmployee);

        newEmployee.Id = employees.Count + 1;
        newEmployee.PositionsQualified = string.Join(", ", selectedPositions);

        employees.Add(newEmployee);
        ClearForm();
    }

    private void DeleteEmployee(Employee employee)
    {
        var hasAssignments = Schedule.Assignments
            .Any(a => a.EmployeeId == employee.Id);

        if (hasAssignments)
        {
            deleteMessage = $"{employee.Name} cannot be deleted because they are assigned to one or more shifts.";
            return;
        }

        Schedule.Employees.Remove(employee);
        deleteMessage = null;
    }

    private HashSet<string> selectedPositions = new();

    private bool IsPositionSelected(string position)
    {
        return selectedPositions.Contains(position);
    }

    private void TogglePosition(string position, bool isChecked)
    {
        if (isChecked)
            selectedPositions.Add(position);
        else
            selectedPositions.Remove(position);

        newEmployee.PositionsQualified =
            string.Join(", ", selectedPositions);
    }

    async Task StartEdit(Employee emp)
    {
        editingEmployee = emp;

        newEmployee = new Employee
        {
            Id = emp.Id,
            CompanyId = emp.CompanyId,
            Name = emp.Name,
            Email = emp.Email,
            MaxHoursPerWeek = emp.MaxHoursPerWeek,
            PositionsQualified = emp.PositionsQualified,

            MondayAvailable = emp.MondayAvailable,
            MondayAnyTime = emp.MondayAnyTime,
            MondayStart = emp.MondayStart,
            MondayEnd = emp.MondayEnd,

            TuesdayAvailable = emp.TuesdayAvailable,
            TuesdayAnyTime = emp.TuesdayAnyTime,
            TuesdayStart = emp.TuesdayStart,
            TuesdayEnd = emp.TuesdayEnd,

            WednesdayAvailable = emp.WednesdayAvailable,
            WednesdayAnyTime = emp.WednesdayAnyTime,
            WednesdayStart = emp.WednesdayStart,
            WednesdayEnd = emp.WednesdayEnd,

            ThursdayAvailable = emp.ThursdayAvailable,
            ThursdayAnyTime = emp.ThursdayAnyTime,
            ThursdayStart = emp.ThursdayStart,
            ThursdayEnd = emp.ThursdayEnd,

            FridayAvailable = emp.FridayAvailable,
            FridayAnyTime = emp.FridayAnyTime,
            FridayStart = emp.FridayStart,
            FridayEnd = emp.FridayEnd,

            SaturdayAvailable = emp.SaturdayAvailable,
            SaturdayAnyTime = emp.SaturdayAnyTime,
            SaturdayStart = emp.SaturdayStart,
            SaturdayEnd = emp.SaturdayEnd,

            SundayAvailable = emp.SundayAvailable,
            SundayAnyTime = emp.SundayAnyTime,
            SundayStart = emp.SundayStart,
            SundayEnd = emp.SundayEnd
        };

        selectedPositions = emp.PositionsQualified
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(p => p.Trim())
            .ToHashSet();

        await Task.Yield();
        await JS.InvokeVoidAsync("scrollToElement", "employee-form");
    }

    void SaveEmployee()
    {
        if (editingEmployee == null)
            return;

        NormalizeAvailability(newEmployee);

        editingEmployee.Name = newEmployee.Name;
        editingEmployee.Email = newEmployee.Email;
        editingEmployee.MaxHoursPerWeek = newEmployee.MaxHoursPerWeek;
        editingEmployee.PositionsQualified = string.Join(", ", selectedPositions);

        editingEmployee.MondayAvailable = newEmployee.MondayAvailable;
        editingEmployee.MondayAnyTime = newEmployee.MondayAnyTime;
        editingEmployee.MondayStart = newEmployee.MondayStart;
        editingEmployee.MondayEnd = newEmployee.MondayEnd;

        editingEmployee.TuesdayAvailable = newEmployee.TuesdayAvailable;
        editingEmployee.TuesdayAnyTime = newEmployee.TuesdayAnyTime;
        editingEmployee.TuesdayStart = newEmployee.TuesdayStart;
        editingEmployee.TuesdayEnd = newEmployee.TuesdayEnd;

        editingEmployee.WednesdayAvailable = newEmployee.WednesdayAvailable;
        editingEmployee.WednesdayAnyTime = newEmployee.WednesdayAnyTime;
        editingEmployee.WednesdayStart = newEmployee.WednesdayStart;
        editingEmployee.WednesdayEnd = newEmployee.WednesdayEnd;

        editingEmployee.ThursdayAvailable = newEmployee.ThursdayAvailable;
        editingEmployee.ThursdayAnyTime = newEmployee.ThursdayAnyTime;
        editingEmployee.ThursdayStart = newEmployee.ThursdayStart;
        editingEmployee.ThursdayEnd = newEmployee.ThursdayEnd;

        editingEmployee.FridayAvailable = newEmployee.FridayAvailable;
        editingEmployee.FridayAnyTime = newEmployee.FridayAnyTime;
        editingEmployee.FridayStart = newEmployee.FridayStart;
        editingEmployee.FridayEnd = newEmployee.FridayEnd;

        editingEmployee.SaturdayAvailable = newEmployee.SaturdayAvailable;
        editingEmployee.SaturdayAnyTime = newEmployee.SaturdayAnyTime;
        editingEmployee.SaturdayStart = newEmployee.SaturdayStart;
        editingEmployee.SaturdayEnd = newEmployee.SaturdayEnd;

        editingEmployee.SundayAvailable = newEmployee.SundayAvailable;
        editingEmployee.SundayAnyTime = newEmployee.SundayAnyTime;
        editingEmployee.SundayStart = newEmployee.SundayStart;
        editingEmployee.SundayEnd = newEmployee.SundayEnd;

        editingEmployee = null;
        newEmployee = new Employee();
        selectedPositions.Clear();
    }

    void ClearForm()
    {
        newEmployee = new Employee
        {
            CompanyId = 1,
            MaxHoursPerWeek = 40
        };

        selectedPositions.Clear();
    }

    private static string FormatTime(TimeSpan? time)
    {
        return time.HasValue ? time.Value.ToString(@"hh\:mm") : "";
    }

    private static TimeSpan? ParseTime(string? value)
    {
        if (TimeSpan.TryParse(value, out var result))
            return result;

        return null;
    }

    string GetAvailabilitySummary(Employee e)
    {
        var parts = new List<string>();

        AddDay(parts, "Mon", e.MondayAvailable, e.MondayAnyTime, e.MondayStart, e.MondayEnd);
        AddDay(parts, "Tue", e.TuesdayAvailable, e.TuesdayAnyTime, e.TuesdayStart, e.TuesdayEnd);
        AddDay(parts, "Wed", e.WednesdayAvailable, e.WednesdayAnyTime, e.WednesdayStart, e.WednesdayEnd);
        AddDay(parts, "Thu", e.ThursdayAvailable, e.ThursdayAnyTime, e.ThursdayStart, e.ThursdayEnd);
        AddDay(parts, "Fri", e.FridayAvailable, e.FridayAnyTime, e.FridayStart, e.FridayEnd);
        AddDay(parts, "Sat", e.SaturdayAvailable, e.SaturdayAnyTime, e.SaturdayStart, e.SaturdayEnd);
        AddDay(parts, "Sun", e.SundayAvailable, e.SundayAnyTime, e.SundayStart, e.SundayEnd);

        return parts.Count > 0 ? string.Join(" | ", parts) : "Unavailable";
    }

    void AddDay(List<string> parts, string day, bool available, bool anyTime, TimeSpan? start, TimeSpan? end)
    {
        if (!available)
            return;

        if (anyTime || (!start.HasValue && !end.HasValue))
        {
            parts.Add($"{day}: AnyTime");
        }
        else if (start.HasValue && end.HasValue)
        {
            parts.Add($"{day}: {DateTime.Today.Add(start.Value):h:mm tt} - {DateTime.Today.Add(end.Value):h:mm tt}");
        }
        else
        {
            parts.Add($"{day}: AnyTime");
        }
    }

    private string FormatDisplayTime(TimeSpan time)
    {
        return DateTime.Today.Add(time).ToString("h:mmtt").ToLower();
    }

    private void AddAvailabilityPart(List<string> parts, string dayLabel, bool available, TimeSpan? start, TimeSpan? end)
    {
        if (!available)
            return;

        if (start.HasValue && end.HasValue)
        {
            parts.Add($"{dayLabel} {FormatDisplayTime(start.Value)}-{FormatDisplayTime(end.Value)}");
        }
        else
        {
            parts.Add($"{dayLabel} Available");
        }
    }

    private void NormalizeAvailability(Employee e)
    {
        NormalizeMonday(e);
        NormalizeTuesday(e);
        NormalizeWednesday(e);
        NormalizeThursday(e);
        NormalizeFriday(e);
        NormalizeSaturday(e);
        NormalizeSunday(e);
    }

    private void NormalizeMonday(Employee e)
    {
        if (!e.MondayAvailable)
        {
            e.MondayAnyTime = false;
            e.MondayStart = null;
            e.MondayEnd = null;
            return;
        }

        if (e.MondayAnyTime || (!e.MondayStart.HasValue && !e.MondayEnd.HasValue))
        {
            e.MondayAnyTime = true;
            e.MondayStart = null;
            e.MondayEnd = null;
            return;
        }

        if (e.MondayStart.HasValue && e.MondayEnd.HasValue)
            return;

        e.MondayAnyTime = true;
        e.MondayStart = null;
        e.MondayEnd = null;
    }

    private void NormalizeTuesday(Employee e)
    {
        if (!e.TuesdayAvailable)
        {
            e.TuesdayAnyTime = false;
            e.TuesdayStart = null;
            e.TuesdayEnd = null;
            return;
        }

        if (e.TuesdayAnyTime || (!e.TuesdayStart.HasValue && !e.TuesdayEnd.HasValue))
        {
            e.TuesdayAnyTime = true;
            e.TuesdayStart = null;
            e.TuesdayEnd = null;
            return;
        }

        if (e.TuesdayStart.HasValue && e.TuesdayEnd.HasValue)
            return;

        e.TuesdayAnyTime = true;
        e.TuesdayStart = null;
        e.TuesdayEnd = null;
    }

    private void NormalizeWednesday(Employee e)
    {
        if (!e.WednesdayAvailable)
        {
            e.WednesdayAnyTime = false;
            e.WednesdayStart = null;
            e.WednesdayEnd = null;
            return;
        }

        if (e.WednesdayAnyTime || (!e.WednesdayStart.HasValue && !e.WednesdayEnd.HasValue))
        {
            e.WednesdayAnyTime = true;
            e.WednesdayStart = null;
            e.WednesdayEnd = null;
            return;
        }

        if (e.WednesdayStart.HasValue && e.WednesdayEnd.HasValue)
            return;

        e.WednesdayAnyTime = true;
        e.WednesdayStart = null;
        e.WednesdayEnd = null;
    }

    private void NormalizeThursday(Employee e)
    {
        if (!e.ThursdayAvailable)
        {
            e.ThursdayAnyTime = false;
            e.ThursdayStart = null;
            e.ThursdayEnd = null;
            return;
        }

        if (e.ThursdayAnyTime || (!e.ThursdayStart.HasValue && !e.ThursdayEnd.HasValue))
        {
            e.ThursdayAnyTime = true;
            e.ThursdayStart = null;
            e.ThursdayEnd = null;
            return;
        }

        if (e.ThursdayStart.HasValue && e.ThursdayEnd.HasValue)
            return;

        e.ThursdayAnyTime = true;
        e.ThursdayStart = null;
        e.ThursdayEnd = null;
    }

    private void NormalizeFriday(Employee e)
    {
        if (!e.FridayAvailable)
        {
            e.FridayAnyTime = false;
            e.FridayStart = null;
            e.FridayEnd = null;
            return;
        }

        if (e.FridayAnyTime || (!e.FridayStart.HasValue && !e.FridayEnd.HasValue))
        {
            e.FridayAnyTime = true;
            e.FridayStart = null;
            e.FridayEnd = null;
            return;
        }

        if (e.FridayStart.HasValue && e.FridayEnd.HasValue)
            return;

        e.FridayAnyTime = true;
        e.FridayStart = null;
        e.FridayEnd = null;
    }

    private void NormalizeSaturday(Employee e)
    {
        if (!e.SaturdayAvailable)
        {
            e.SaturdayAnyTime = false;
            e.SaturdayStart = null;
            e.SaturdayEnd = null;
            return;
        }

        if (e.SaturdayAnyTime || (!e.SaturdayStart.HasValue && !e.SaturdayEnd.HasValue))
        {
            e.SaturdayAnyTime = true;
            e.SaturdayStart = null;
            e.SaturdayEnd = null;
            return;
        }

        if (e.SaturdayStart.HasValue && e.SaturdayEnd.HasValue)
            return;

        e.SaturdayAnyTime = true;
        e.SaturdayStart = null;
        e.SaturdayEnd = null;
    }

    private void NormalizeSunday(Employee e)
    {
        if (!e.SundayAvailable)
        {
            e.SundayAnyTime = false;
            e.SundayStart = null;
            e.SundayEnd = null;
            return;
        }

        if (e.SundayAnyTime || (!e.SundayStart.HasValue && !e.SundayEnd.HasValue))
        {
            e.SundayAnyTime = true;
            e.SundayStart = null;
            e.SundayEnd = null;
            return;
        }

        if (e.SundayStart.HasValue && e.SundayEnd.HasValue)
            return;

        e.SundayAnyTime = true;
        e.SundayStart = null;
        e.SundayEnd = null;
    }

    private void NormalizeDay(ref bool available, ref bool anyTime, ref TimeSpan? start, ref TimeSpan? end)
    {
        if (!available)
        {
            anyTime = false;
            start = null;
            end = null;
            return;
        }

        if (anyTime || (!start.HasValue && !end.HasValue))
        {
            anyTime = true;
            start = null;
            end = null;
            return;
        }

        if (start.HasValue && end.HasValue)
        {
            return;
        }

        anyTime = true;
        start = null;
        end = null;
    }

    private void OnMondayAnyTimeChanged(bool value)
    {
        newEmployee.MondayAnyTime = value;

        if (value)
        {
            newEmployee.MondayStart = null;
            newEmployee.MondayEnd = null;
        }
    }

    private void OnTuesdayAnyTimeChanged(bool value)
    {
        newEmployee.TuesdayAnyTime = value;

        if (value)
        {
            newEmployee.TuesdayStart = null;
            newEmployee.TuesdayEnd = null;
        }
    }

    private void OnWednesdayAnyTimeChanged(bool value)
    {
        newEmployee.WednesdayAnyTime = value;

        if (value)
        {
            newEmployee.WednesdayStart = null;
            newEmployee.WednesdayEnd = null;
        }
    }

    private void OnThursdayAnyTimeChanged(bool value)
    {
        newEmployee.ThursdayAnyTime = value;

        if (value)
        {
            newEmployee.ThursdayStart = null;
            newEmployee.ThursdayEnd = null;
        }
    }

    private void OnFridayAnyTimeChanged(bool value)
    {
        newEmployee.FridayAnyTime = value;

        if (value)
        {
            newEmployee.FridayStart = null;
            newEmployee.FridayEnd = null;
        }
    }

    private void OnSaturdayAnyTimeChanged(bool value)
    {
        newEmployee.SaturdayAnyTime = value;

        if (value)
        {
            newEmployee.SaturdayStart = null;
            newEmployee.SaturdayEnd = null;
        }
    }

    private void OnSundayAnyTimeChanged(bool value)
    {
        newEmployee.SundayAnyTime = value;

        if (value)
        {
            newEmployee.SundayStart = null;
            newEmployee.SundayEnd = null;
        }
    }
}