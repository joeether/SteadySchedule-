@page
@model SteadySchedule.Pages.Account.RegisterModel
@{
	ViewData["Title"] = "Register";
}

<link rel="stylesheet" href="/bootstrap/bootstrap.min.css" />

<style>
	.login-page {
		min-height: 100vh;
		display: flex;
		justify-content: center;
		align-items: center;
		background: linear-gradient(135deg, #1e293b, #0f172a);
	}

	.login-page input:not([type="checkbox"]) {
		width: 100%;
	}

	.login-card-wrapper {
		width: 100%;
		max-width: 600px;
		padding: 25px;
	}

	.login-page .card {
		background: white;
		width: 100%;
		border-radius: 16px;
		box-shadow: 0 15px 40px rgba(0,0,0,0.25);
	}

	.login-page .card-header {
		text-align: center;
		font-size: 1.4rem;
		padding-top: 25px;
		border-bottom: none;
	}

	.login-page .card-body {
		padding: 30px;
	}

	.login-page .form-control {
		border-radius: 10px;
		padding: 12px;
		font-size: 15px;
	}

	.login-page button[type="submit"] {
		width: 100%;
		margin-top: 10px;
		border-radius: 8px;
	}

	.login-page label {
		display: block;
		margin-bottom: 5px;
	}

	.login-page .btn-dark {
		background: linear-gradient(135deg, #007bff, #0056b3);
		border: none;
		font-weight: bold;
		padding: 12px;
	}

	.login-page .btn-dark:hover {
		transform: translateY(-1px);
	}

	img {
		transition: transform 0.2s ease;
	}

	img:hover {
		transform: scale(1.05);
	}

	.is-invalid {
		border: 2px solid #dc3545 !important;
		box-shadow: 0 0 5px rgba(220,53,69,.5);
	}
</style>


<div class="modal fade" id="termsModal" tabindex="-1" aria-labelledby="termsModalLabel" aria-hidden="true">
	<div class="modal-dialog modal-dialog-scrollable modal-lg">
		<div class="modal-content">

			<div class="modal-header">
				<h5 class="modal-title" id="termsModalLabel">
					Terms & Conditions
				</h5>

				<button type="button"
						class="btn-close"
						data-bs-dismiss="modal"
						aria-label="Close"
						onclick="this.blur();">
				</button>
			</div>

			<div class="modal-body">

				<h6>Use of Service</h6>
				<p>
					SteadySchedule provides employee scheduling software designed for small businesses. Access to the platform is provided on a subscription basis following any applicable free trial period.
				</p>

				<h6>Account Responsibility</h6>
				<p>
					Users are responsible for maintaining the confidentiality of their account credentials and ensuring the information entered into the platform is accurate and up to date.
				</p>

				<h6>No Warranty</h6>
				<p>
					SteadySchedule is provided "as is" without warranties of any kind. We are not responsible for scheduling conflicts, lost business, downtime, or interruptions resulting from use of the service.
				</p>

				<h6>Billing & Cancellation</h6>
				<p>
					Subscriptions may be canceled at any time. Failure to submit payment after the trial period may result in suspension or termination of access to the platform.
				</p>

				<h6>Changes to Terms</h6>
				<p>
					We reserve the right to update or modify these Terms of Service at any time. Continued use of the platform constitutes acceptance of any updated terms.
				</p>

			</div>

			<div class="modal-footer">
				<button type="button"
						class="btn btn-secondary"
						data-bs-dismiss="modal"
						onclick="this.blur();">
					Close
				</button>
			</div>

		</div>
	</div>
</div>

<div class="modal fade" id="privacyModal" tabindex="-1" aria-labelledby="privacyModalLabel" aria-hidden="true">
	<div class="modal-dialog modal-dialog-scrollable modal-lg">
		<div class="modal-content">

			<div class="modal-header">
				<h5 class="modal-title" id="privacyModalLabel">
					Privacy Policy
				</h5>

				<button type="button"
						class="btn-close"
						data-bs-dismiss="modal"
						aria-label="Close"
						onclick="this.blur();">
				</button>
			</div>

			<div class="modal-body">

				<h6>Information We Collect</h6>
				<p>
					SteadySchedule collects basic information necessary to provide our services, including account details, employee information, and scheduling data entered by users.
				</p>

				<h6>How Information Is Used</h6>
				<p>
					The information collected is used solely to operate and improve the SteadySchedule platform and provide scheduling-related features.
				</p>

				<h6>Third-Party Services</h6>
				<p>
					We do not sell or share personal information with third parties except as required to operate the service, process payments securely, or comply with legal obligations.
				</p>

				<h6>Data Security</h6>
				<p>
					We take reasonable measures to protect your information, but no system can guarantee complete security.
				</p>

				<h6>Consent</h6>
				<p>
					By using SteadySchedule, you consent to this Privacy Policy.
				</p>

				<h6>Policy Updates</h6>
				<p>
					This Privacy Policy may be updated periodically. Continued use of the platform constitutes acceptance of any updates.
				</p>

				<p class="text-muted mt-4">
					Last updated: May 3, 2026
				</p>

			</div>

			<div class="modal-footer">
				<button type="button"
						class="btn btn-secondary"
						data-bs-dismiss="modal"
						onclick="this.blur();">
					Close
				</button>
			</div>

		</div>
	</div>
</div>

<div class="login-page">
	<div class="login-card-wrapper">
		<div class="card shadow-sm">
			<div class="card-header fw-semibold">
				<div class="text-center mb-3">
					<img src="/images/steadyschedule-logo.png"
						 alt="SteadySchedule"
						 style="max-height: 120px;" />
				</div>

				<h6 class="text-muted text-center mb-3">
					Welcome to SteadySchedule! Create your account.
				</h6>
			</div>
			<div class="card-body">
				<form method="post">
					@if (!ViewData.ModelState.IsValid)
					{
						<div asp-validation-summary="All"
							 class="alert alert-warning alert-validation mb-3">
						</div>
					}

					<div class="mb-3">
						<label asp-for="Input.CompanyName" class="form-label"></label>
						<input asp-for="Input.CompanyName" class="form-control" />
						<span asp-validation-for="Input.CompanyName" class="text-danger"></span>
					</div>

					<div class="mb-3">
						<label asp-for="Input.Email" class="form-label"></label>
						<input asp-for="Input.Email" class="form-control" autocomplete="off" />
						<span asp-validation-for="Input.Email" class="text-danger"></span>
					</div>

					<div class="mb-3">
						<label asp-for="Input.Password" class="form-label"></label>

						<div class="input-group">
							<input asp-for="Input.Password"
								   type="password"
								   class="form-control @(ViewData.ModelState[string.Empty]?.Errors.Count > 0 ? "is-invalid" : "")" autocomplete="new-password" />

							<button type="button"
									class="btn btn-outline-secondary"
									onclick="this.previousElementSibling.type = this.previousElementSibling.type === 'password' ? 'text' : 'password'">
								👁
							</button>
						</div>

						<span asp-validation-for="Input.Password" class="text-danger"></span>
					</div>

					<div class="mb-3">
						<label asp-for="Input.ConfirmPassword" class="form-label"></label>

						<div class="input-group">
							<input asp-for="Input.ConfirmPassword"
								   type="password"
								   class="form-control @(ViewData.ModelState.ErrorCount > 0 ? "is-invalid" : "")" autocomplete="new-password" />

							<button type="button"
									class="btn btn-outline-secondary"
									onclick="this.previousElementSibling.type = this.previousElementSibling.type === 'password' ? 'text' : 'password'">
								👁
							</button>
						</div>

						<span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
					</div>

					@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
					{
						<div class="alert alert-danger">
							@Model.ErrorMessage
						</div>
					}

					<div class="form-check mt-4 mb-3">
						<input type="checkbox"
							   class="form-check-input"
							   asp-for="Input.AcceptedTerms" />

						<label class="form-check-label">
							I agree to the
							<button type="button"
									class="btn btn-link p-0 align-baseline"
									data-bs-toggle="modal"
									data-bs-target="#termsModal">
								Terms
							</button>
							and
							<button type="button"
									class="btn btn-link p-0 align-baseline"
									data-bs-toggle="modal"
									data-bs-target="#privacyModal">
								Privacy Policy
							</button>
						</label>
					</div>

					<span asp-validation-for="Input.AcceptedTerms"
						  class="text-danger d-block mb-3">
					</span>

					<div class="form-text mb-4">
						Includes a 30-day free trial. No credit card required.
					</div>

					<button type="submit" class="btn btn-dark w-100 mb-3">
						Create Account
					</button>

					<div class="text-center mt-3">
						<span class="text-muted">Already have an account?</span>
						<a href="/Account/Login">Log in</a>
					</div>
				</form>
			</div>
		</div>
	</div>
</div>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

