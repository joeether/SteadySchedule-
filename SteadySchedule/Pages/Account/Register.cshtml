@page
@model SteadySchedule.Pages.Account.RegisterModel
@{
	ViewData["Title"] = "Register";
}

<style>
	.login-page {
		position: fixed;
		inset: 0;
		display: flex;
		justify-content: center;
		align-items: center;
		background: linear-gradient(135deg, #1e293b, #0f172a);
	}

		.login-page input {
			width: 100%;
		}

	.login-card-wrapper {
		width: 100%;
		max-width: 600px;
		padding: 25px;
	}

	.login-page .card {
		background: white;
		width: 100%;
		border-radius: 16px;
		box-shadow: 0 15px 40px rgba(0,0,0,0.25);
	}

	.login-page .card-header {
		text-align: center;
		font-size: 1.4rem;
		padding-top: 25px;
		border-bottom: none;
	}

	.login-page .card-body {
		padding: 30px;
	}

	.login-page .form-control {
		border-radius: 10px;
		padding: 12px;
		font-size: 15px;
	}

	.login-page button[type="submit"] {
		width: 100%;
		margin-top: 10px;
		border-radius: 8px;
	}

	.login-page label {
		display: block;
		margin-bottom: 5px;
	}

	.login-page .btn-dark {
		background: linear-gradient(135deg, #007bff, #0056b3);
		border: none;
		font-weight: bold;
		padding: 12px;
	}

		.login-page .btn-dark:hover {
			transform: translateY(-1px);
		}

	img {
		transition: transform 0.2s ease;
	}

		img:hover {
			transform: scale(1.05);
		}
</style>

<div class="login-page">
	<div class="login-card-wrapper">
		<div class="card shadow-sm">
			<div class="card-header fw-semibold">
				<div class="text-center mb-3">
					<img src="/images/steadyschedule-logo.png"
						 alt="SteadySchedule"
						 style="max-height: 120px;" />
				</div>

				<h6 class="text-muted text-center mb-3">
					Welcome to SteadySchedule! Create your account.
				</h6>
			</div>
			<div class="card-body">
				<form method="post">
					<div asp-validation-summary="All"
     class="alert alert-warning mb-3">
</div>

					<div class="mb-3">
						<label asp-for="Input.CompanyName" class="form-label"></label>
						<input asp-for="Input.CompanyName" class="form-control" />
						<span asp-validation-for="Input.CompanyName" class="text-danger"></span>
					</div>

					<div class="mb-3">
						<label asp-for="Input.Email" class="form-label"></label>
						<input asp-for="Input.Email" class="form-control" autocomplete="off" />
						<span asp-validation-for="Input.Email" class="text-danger"></span>
					</div>

					<div class="mb-3">
						<label asp-for="Input.Password" class="form-label"></label>

						<div class="input-group">
							<input asp-for="Input.Password"
								   type="password"
								   class="form-control @(ViewData.ModelState["Input.Password"]?.Errors.Count > 0 ? "is-invalid" : "")" autocomplete="new-password" />

							<button type="button"
									class="btn btn-outline-secondary"
									onclick="this.previousElementSibling.type = this.previousElementSibling.type === 'password' ? 'text' : 'password'">
								👁
							</button>
						</div>

						<span asp-validation-for="Input.Password" class="text-danger"></span>
					</div>

					<div class="mb-3">
						<label asp-for="Input.ConfirmPassword" class="form-label"></label>

						<div class="input-group">
							<input asp-for="Input.ConfirmPassword"
								   type="password"
								   class="form-control @(ViewData.ModelState["Input.ConfirmPassword"]?.Errors.Count > 0 ? "is-invalid" : "")" autocomplete="new-password" />

							<button type="button"
									class="btn btn-outline-secondary"
									onclick="this.previousElementSibling.type = this.previousElementSibling.type === 'password' ? 'text' : 'password'">
								👁
							</button>
						</div>

						<span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
					</div>

					@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
					{
						<div class="alert alert-danger">
							@Model.ErrorMessage
						</div>
					}

                    <div class="form-check mt-4 mb-3">
    <input type="checkbox"
           class="form-check-input"
           asp-for="Input.AcceptedTerms" />

    <label class="form-check-label" asp-for="Input.AcceptedTerms">
        I agree to the
        <a href="#"
   data-bs-toggle="modal"
   data-bs-target="#termsModal">
    Terms
</a>
        and
        <a href="#"
   data-bs-toggle="modal"
   data-bs-target="#privacyModal">
    Privacy Policy
</a>
    </label>
</div>

<span asp-validation-for="Input.AcceptedTerms"
      class="text-danger d-block mb-3">
</span>

<div class="form-text mb-4">
    Includes a 30-day free trial. No credit card required.
</div>

<button type="submit" class="btn btn-dark w-100 mb-3">
    Create Account
</button>

<div class="text-center mt-3">
    <span class="text-muted">Already have an account?</span>
    <a href="/Account/Login">Log in</a>
</div>
				</form>
			</div>
		</div>
	</div>
</div>

<div class="modal fade" id="termsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-scrollable modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Terms & Conditions</h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body">

                <p>Your Terms text here...</p>

            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="privacyModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-scrollable modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Privacy Policy</h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body">

                <p>Your Privacy text here...</p>

            </div>

        </div>
    </div>
</div>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />
}
