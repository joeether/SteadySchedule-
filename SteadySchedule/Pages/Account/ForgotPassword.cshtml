@page
@model SteadySchedule.Pages.Account.ForgotPasswordModel

<h3>Forgot Password</h3>

<form method="post">
    <input asp-for="Email" placeholder="Enter your email" />
    <button type="submit">Generate Reset Token</button>
</form>

@if (Model.ResetLink != null)
{
    <div style="margin-top:20px;">
        <a href="@Model.ResetLink">Click here to reset password</a>
    </div>
}