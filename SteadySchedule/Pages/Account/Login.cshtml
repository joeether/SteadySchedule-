@page
@model SteadySchedule.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Log in";
}

<style>
.login-page {
    position: fixed;
    inset: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    background: linear-gradient(135deg, #1e293b, #0f172a);
}

.login-page input {
    width: 100%;
}

.login-card-wrapper {
    width: 100%;
    max-width: 600px;
    padding: 25px;
}

.login-page .card {
    background: white;
    width: 100%;
    border-radius: 16px;
    box-shadow: 0 15px 40px rgba(0,0,0,0.25);
}

.login-page .card-header {
    text-align: center;
    font-size: 1.4rem;
    padding-top: 25px;
    border-bottom: none;
}

.login-page .card-body {
    padding: 30px;
}

.login-page .form-control {
    border-radius: 10px;
    padding: 12px;
    font-size: 15px;
}

.login-page button[type="submit"] {
    width: 100%;
    margin-top: 10px;
    border-radius: 8px;
}

.login-page label {
    display: block;
    margin-bottom: 5px;
}

.login-page .btn-dark {
    background: linear-gradient(135deg, #007bff, #0056b3);
    border: none;
    font-weight: bold;
    padding: 12px;
}

.login-page .btn-dark:hover {
    transform: translateY(-1px);
}

.login-page a {
    color: #0056b3;
    font-weight: 600;
    text-decoration: none;
}

.login-page a:hover {
     text-decoration: underline;
}

img {
    transition: transform 0.2s ease;
}

img:hover {
    transform: scale(1.05);
}
</style>

<div class="login-page">
    <div class="login-card-wrapper">
    <div class="card shadow-sm">
        <div class="card-header fw-semibold">
        <div class="text-center mb-3">
        <img src="/images/steadyschedule-logo.png"
             alt="SteadySchedule"
             style="max-height: 120px;" />
    </div>

    <h6 class="text-muted text-center mb-3">
        Tools that don’t make you feel stupid
    </h6>
</div>
        <div class="card-body">
            <form method="post">
                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label"></label>
                    <input asp-for="Input.Email" class="form-control" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
    <label asp-for="Input.Password" class="form-label"></label>

    <div class="input-group">
        <input asp-for="Input.Password"
               type="password"
               class="form-control" />

        <button type="button"
                class="btn btn-outline-secondary"
                onclick="this.previousElementSibling.type = this.previousElementSibling.type === 'password' ? 'text' : 'password'">
            👁
        </button>
    </div>

    <span asp-validation-for="Input.Password" class="text-danger"></span>
</div>
                <div class="text-end mb-2">
                        <a href="/Account/ForgotPassword">Forgot your password?</a>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="Input.RememberMe" class="form-check-input" />
                    <label asp-for="Input.RememberMe" class="form-check-label"></label>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div class="alert alert-danger">
                        @Model.ErrorMessage
                    </div>
                }

                <button type="submit" class="btn btn-dark w-100">
                    Log In
                </button>
                    <div class="text-center mt-3">
                        <span class="text-muted">Need an account?</span>
                        <a href="/Account/Register">Register</a>
                    </div>
            </form>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
