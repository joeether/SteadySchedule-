@page "/myschedule"
@using Microsoft.AspNetCore.Components.Authorization
@using SteadySchedule.Domain
@using SteadySchedule.Services
@inject AuthenticationStateProvider AuthStateProvider
@inject ScheduleService Schedule

<h3>My Schedule</h3>
<p class="text-muted">View your upcoming shifts</p>

<div class="d-flex justify-content-between align-items-center mb-3">

    <select class="form-select w-auto"
            value="@selectedWeek.ToString("yyyy-MM-dd")"
            @onchange="OnWeekChanged">

        @foreach (var w in publishedWeeks.Where(w => w >= StartOfWeek(DateTime.Today)))
        {
            <option value="@w.ToString("yyyy-MM-dd")">
                Week of @w.ToString("MMM d")
            </option>
        }
    </select>

    <button class="btn btn-sm btn-outline-secondary"
            @onclick="ToggleView">
        @(showAll ? "My Schedule" : "All Employees")
    </button>

</div>

@if (isLoading)
{
    <p>Loading...</p>
}
else if (!filteredAssignments.Any())
{
    <p>No shifts scheduled.</p>
}
else
{
    <div class="schedule-container">
        @foreach (var a in filteredAssignments.OrderBy(a => a.Shift.Date))
        {
            var emp = employees.FirstOrDefault(e => e.Id == a.EmployeeId);

            <div class="shift-card @(a.Shift.Date.Date == DateTime.Today ? "today" : "")">

                <div class="shift-date">
                    @a.Shift.Date.ToString("dddd, MMM d")

                    @if (a.Shift.Date.Date == DateTime.Today)
                    {
                        <span class="today-badge">Today</span>
                    }
                </div>

                @if (showAll && emp is not null)
                {
                    <div class="employee-name">
                        @emp.Name
                    </div>
                }

                <div class="shift-details">
                    <span class="position">@a.Shift.Position</span>
                    <span class="time">
                        @FormatDisplayTime(a.Shift.StartTime)
                        -
                        @FormatDisplayTime(a.Shift.EndTime)
                    </span>
                </div>

            </div>
        }
    </div>
}

@code {

    private int companyId;
    private int employeeId;

    private List<DateTime> publishedWeeks = new();
    private DateTime selectedWeek;

    private List<Assignment> selectedWeekAssignments = new();
    private List<Assignment> filteredAssignments = new();
    private List<Employee> employees = new();

    private bool showAll = false;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        companyId = int.Parse(user.FindFirst("CompanyId")!.Value);
        employeeId = int.Parse(user.FindFirst("EmployeeId")!.Value);

        publishedWeeks = (await Schedule.GetPublishedSchedulesAsync(companyId))
            .Select(s => s.WeekStart.Date)
            .Distinct()
            .OrderBy(d => d)
            .ToList();

        var currentWeek = StartOfWeek(DateTime.Today);

        selectedWeek = publishedWeeks.Contains(currentWeek)
            ? currentWeek
            : publishedWeeks.FirstOrDefault();

        await LoadWeek();
    }

    private async Task LoadWeek()
{
    isLoading = true;
    StateHasChanged(); //add this

    selectedWeekAssignments =
        await Schedule.GetWeekAssignmentsAsync(companyId, selectedWeek);

    employees =
        await Schedule.GetEmployeesAsync(companyId);

    ApplyFilter();

    isLoading = false;
    StateHasChanged(); //add this
}

    private void ApplyFilter()
    {
        filteredAssignments = showAll
            ? selectedWeekAssignments
            : selectedWeekAssignments
                .Where(a => a.EmployeeId == employeeId)
                .ToList();
    }

    private async Task OnWeekChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var week))
        {
            selectedWeek = week;
            await LoadWeek();
        }
    }

    private void ToggleView()
{
    showAll = !showAll;
    ApplyFilter();
    StateHasChanged(); // add this
}

private async Task OnWeekChanged(ChangeEventArgs e)
{
    Console.WriteLine("Week changed fired");

    if (DateTime.TryParse(e.Value?.ToString(), out var week))
    {
        selectedWeek = week;
        await LoadWeek();
    }
}

    private static DateTime StartOfWeek(DateTime date)
    {
        int diff = (7 + (date.DayOfWeek - DayOfWeek.Monday)) % 7;
        return date.Date.AddDays(-diff);
    }

    private string FormatDisplayTime(TimeSpan time)
    {
        return DateTime.Today.Add(time).ToString("h:mm tt");
    }
}