@page "/myschedule"
@using Microsoft.AspNetCore.Components.Authorization
@using SteadySchedule.Domain
@using SteadySchedule.Services
@inject AuthenticationStateProvider AuthStateProvider
@inject ScheduleService Schedule

<h3>My Schedule</h3>
<p class="text-muted">Here are your upcoming shifts</p>
<h5 class="mb-3">This Week</h5>

@if (assignments == null)
{
    <p>Loading...</p>
}
else if (!assignments.Any())
{
    <p>No shifts scheduled.</p>
}
else
{
    <div class="schedule-container">
    @foreach (var a in assignments.OrderBy(a => a.Shift.Date))
    {
        <div class="shift-card">
            <div class="shift-date">
    @a.Shift.Date.ToString("dddd, MMM d")

    @if (a.Shift.Date.Date == DateTime.Today)
    {
        <span class="today-badge">Today</span>
    }
</div>

            <div class="shift-details">
                <span class="position">@a.Shift.Position</span>
                <span class="time">
                    @FormatDisplayTime(a.Shift.StartTime)
                    -
                    @FormatDisplayTime(a.Shift.EndTime)
                </span>
            </div>
        </div>
    }
</div>
}

@code {
    private List<Assignment> assignments = new();
    private int debugAssignmentCount;
    private int companyId;
    private int employeeId;
    private List<Assignment> allAssignments = new();
    private string FormatDisplayTime(TimeSpan time)
{
    return DateTime.Today.Add(time).ToString("h:mm tt");
}

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        companyId = int.Parse(user.FindFirst("CompanyId")!.Value);
        employeeId = int.Parse(user.FindFirst("EmployeeId")!.Value);

        var today = DateTime.Today;
        var diff = (7 + (today.DayOfWeek - DayOfWeek.Monday)) % 7;
        var weekStart = today.AddDays(-diff);

        allAssignments = await Schedule.GetWeekAssignmentsAsync(companyId, weekStart);

        debugAssignmentCount = allAssignments.Count;

        assignments = allAssignments
            .Where(a => a.EmployeeId == employeeId)
            .ToList();
    }
}
